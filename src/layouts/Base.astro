---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
}

const { title, description = '產品人的 AI 轉型指南 — 從 AI 產品策略、工具實戰到職涯轉型，資深 PM 的第一手觀察與實踐。', ogImage = '', noindex = false } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!DOCTYPE html>
<html lang="zh-Hant" class="scroll-smooth" style="overflow-x:hidden;">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="icon" href="/favicon.ico" sizes="32x32">
<link rel="apple-touch-icon" href="/apple-touch-icon.png">
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />
{noindex && <meta name="robots" content="noindex, nofollow" />}
<meta name="google-site-verification" content="Y1o5i5ud5dxL04i4mfOsfviUwUZbtEbLmVLjFBdV5H0" />
<meta name="msvalidate.01" content="4DBEE2E3BFD6DE1C7177AB8C0CEBE864" />

<!-- Google Analytics -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-XY1PQ9JQVG" is:inline></script>
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-XY1PQ9JQVG');
</script>

<!-- Open Graph / LinkedIn -->
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage || new URL('/og-cover.png', Astro.site).toString()} />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage || new URL('/og-cover.png', Astro.site).toString()} />

<!-- JSON-LD Structured Data -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Angela Jian 簡琬庭",
  "jobTitle": "Sr. Product Manager / AI Product Builder",
  "url": Astro.site?.toString(),
  "image": new URL('/angela.jpeg', Astro.site).toString(),
  "sameAs": [
    "https://www.linkedin.com/in/angela-jian/"
  ],
  "knowsAbout": ["Product Management", "AI Product Development", "Growth Strategy", "Monetization", "Mobile Apps"],
  "description": "資深產品經理，擅長從 0 到 1 打造 AI 產品，8 年以上行動應用成長與變現經驗。"
})} />
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "AI PM INSIDER",
  "url": Astro.site?.toString(),
  "description": "Angela Jian 的產品管理與 AI 產品思維部落格",
  "author": { "@type": "Person", "name": "Angela Jian 簡琬庭" }
})} />

<!-- Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Noto+Sans+TC:wght@300;400;500;700;900&display=swap" rel="stylesheet">

<!-- External Libraries -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" is:inline></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js" is:inline></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollToPlugin.min.js" is:inline></script>
<script src="https://code.iconify.design/iconify-icon/2.1.0/iconify-icon.min.js" is:inline></script>

<!-- Global CSS -->
</head>
<body style="overflow-x:hidden; max-width:100%; width:100%;">

<!-- Loading Screen -->
<div id="loader">
  <div style="font-family: Inter, sans-serif; font-weight: 900; font-size: 1.2rem; letter-spacing: 0.1em; background: linear-gradient(135deg, #D4B86A, #E8D48B, #C5A55A, #A8893E); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">AI PM INSIDER</div>
  <div class="loader-bar"><div class="loader-bar-inner" id="loaderBar"></div></div>
  <div style="font-family: Inter, sans-serif; font-size: 0.75rem; color: #9ca3af; letter-spacing: 0.05em;">LOADING</div>
</div>

<!-- Custom Cursor -->
<div class="cursor-main" id="cursorMain"></div>
<div class="cursor-trail" id="cursorTrail"></div>

<!-- Navigation -->
<nav class="nav-glass fixed top-0 left-0 w-full z-50 px-6 py-4 md:py-5 flex items-center justify-between" id="mainNav">
  <a href="/" class="font-heading font-bold text-lg tracking-widest gold-text">AI PM<span class="text-white"> INSIDER</span></a>
  <div class="hidden md:flex items-center gap-8 text-sm font-body text-gray-400">
    <a href="/#articles" class="hover:text-brand-accent transition-colors duration-300">文章</a>
    <a href="/ipas" class="hover:text-brand-accent transition-colors duration-300">iPAS 課程</a>
    <a href="/exam" class="hover:text-brand-accent transition-colors duration-300">題庫</a>
    <a href="/ai-certifications" class="hover:text-brand-accent transition-colors duration-300">AI 證照</a>
    <a href="/#portfolio" class="hover:text-brand-accent transition-colors duration-300">作品集</a>
  </div>
  <div class="flex items-center gap-3">
    <a href="mailto:aipm.insider@gmail.com" class="hidden md:inline-flex mag-btn px-5 py-2.5 gold-gradient text-white rounded-full text-sm font-body font-medium">
      <span>與我聊聊</span>
    </a>
    <!-- Mobile Menu Button -->
    <button id="mobileMenuBtn" class="md:hidden w-10 h-10 flex items-center justify-center text-gray-300" aria-label="選單">
      <iconify-icon icon="solar:hamburger-menu-linear" class="text-2xl"></iconify-icon>
    </button>
  </div>
</nav>

<!-- Mobile Menu Overlay -->
<div id="mobileMenu" class="fixed inset-0 z-[60] bg-white/95 backdrop-blur-lg hidden flex-col items-center justify-center gap-8">
  <button id="mobileMenuClose" class="absolute top-5 right-6 w-10 h-10 flex items-center justify-center text-brand-text" aria-label="關閉">
    <iconify-icon icon="solar:close-circle-linear" class="text-3xl"></iconify-icon>
  </button>
  <a href="/#articles" class="mobile-nav-link font-heading text-2xl text-brand-text hover:text-brand-accent transition-colors">文章</a>
  <a href="/ipas" class="mobile-nav-link font-heading text-2xl text-brand-text hover:text-brand-accent transition-colors">iPAS 課程</a>
  <a href="/exam" class="mobile-nav-link font-heading text-2xl text-brand-text hover:text-brand-accent transition-colors">題庫</a>
  <a href="/ai-certifications" class="mobile-nav-link font-heading text-2xl text-brand-text hover:text-brand-accent transition-colors">AI 證照</a>
  <a href="/#portfolio" class="mobile-nav-link font-heading text-2xl text-brand-text hover:text-brand-accent transition-colors">作品集</a>
  <a href="mailto:aipm.insider@gmail.com" class="mag-btn mt-4 px-8 py-4 gold-gradient text-white font-heading font-semibold rounded-full text-base">
    <span>與我聊聊</span>
  </a>
</div>

<script is:inline>
  document.getElementById('mobileMenuBtn')?.addEventListener('click', () => {
    const menu = document.getElementById('mobileMenu');
    menu.classList.remove('hidden');
    menu.classList.add('flex');
  });
  document.getElementById('mobileMenuClose')?.addEventListener('click', () => {
    const menu = document.getElementById('mobileMenu');
    menu.classList.add('hidden');
    menu.classList.remove('flex');
  });
  document.querySelectorAll('.mobile-nav-link').forEach(link => {
    link.addEventListener('click', () => {
      const menu = document.getElementById('mobileMenu');
      menu.classList.add('hidden');
      menu.classList.remove('flex');
    });
  });
</script>

<!-- Page Content -->
<slot />

<!-- Footer -->
<footer class="py-12 border-t border-brand-light-border relative z-10 bg-[#1a1814]">
  <div class="site-container px-6">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="font-heading font-bold text-sm tracking-widest text-brand-accent">AI PM<span class="text-white"> INSIDER</span></div>
      <p class="text-xs text-gray-400 font-body">&copy; 2026 Angela Jian. Crafted with passion & pixels.</p>
      <div class="flex items-center gap-1 text-xs text-gray-400 font-body">
        <span>Built with</span>
        <iconify-icon icon="solar:heart-bold" class="text-red-400"></iconify-icon>
        <span>and</span>
        <iconify-icon icon="solar:cup-hot-bold" class="text-brand-accent"></iconify-icon>
      </div>
    </div>
  </div>
</footer>

<!-- Global Scripts -->
<script is:inline src="/scripts/main.js"></script>


</body>
</html>
