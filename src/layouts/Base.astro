---
export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = 'Sr. Product Manager / AI Product Builder — 8+ years driving global growth and monetization for high-scale mobile apps.', ogImage = '' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!DOCTYPE html>
<html lang="zh-Hant" class="scroll-smooth" style="overflow-x:hidden;">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />

<!-- Open Graph / LinkedIn -->
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage || '/angela.jpeg'} />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage || '/angela.jpeg'} />

<!-- JSON-LD Structured Data -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Angela Jian 簡琬庭",
  "jobTitle": "Sr. Product Manager / AI Product Builder",
  "url": Astro.site?.toString(),
})} />

<!-- Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Geologica:wght@300;400;500;600;700;800;900&family=Space+Grotesk:wght@300;400;500;600;700&family=Noto+Sans+TC:wght@300;400;500;700;900&display=swap" rel="stylesheet">

<!-- External Libraries -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" is:inline></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js" is:inline></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollToPlugin.min.js" is:inline></script>
<script src="https://code.iconify.design/iconify-icon/2.1.0/iconify-icon.min.js" is:inline></script>

<!-- Global CSS -->
<style>
  @import "../styles/global.css";
</style>
</head>
<body style="overflow-x:hidden; max-width:100%; width:100%;">

<!-- Loading Screen -->
<div id="loader">
  <div style="font-family: Geologica, sans-serif; font-weight: 900; font-size: 1.2rem; letter-spacing: 0.1em; color: #6366f1;">ANGELA JIAN</div>
  <div class="loader-bar"><div class="loader-bar-inner" id="loaderBar"></div></div>
  <div style="font-family: Geologica, sans-serif; font-size: 0.75rem; color: #9ca3af; letter-spacing: 0.05em;">LOADING</div>
</div>

<!-- Custom Cursor -->
<div class="cursor-main" id="cursorMain"></div>
<div class="cursor-trail" id="cursorTrail"></div>

<!-- Navigation -->
<nav class="nav-glass fixed top-0 left-0 w-full z-50 px-6 py-4 md:py-5 flex items-center justify-between" id="mainNav">
  <a href="/" class="font-heading font-bold text-lg tracking-widest text-brand-accent">ANGELA<span class="text-brand-text">.JIAN</span></a>
  <div class="hidden md:flex items-center gap-8 text-sm font-body text-brand-subtle">
    <a href="/#about" class="hover:text-brand-accent transition-colors duration-300">關於我</a>
    <a href="/#portfolio" class="hover:text-brand-accent transition-colors duration-300">作品集</a>
    <a href="/#articles" class="hover:text-brand-accent transition-colors duration-300">文章</a>
    <a href="/#contact" class="hover:text-brand-accent transition-colors duration-300">聯繫</a>
  </div>
  <div class="flex items-center gap-3">
    <a href="/#contact" class="hidden md:inline-flex mag-btn px-5 py-2.5 bg-brand-accent text-white rounded-full text-sm font-body font-medium">
      <span>開始合作</span>
    </a>
    <!-- Mobile Menu Button -->
    <button id="mobileMenuBtn" class="md:hidden w-10 h-10 flex items-center justify-center text-brand-text" aria-label="選單">
      <iconify-icon icon="solar:hamburger-menu-linear" class="text-2xl"></iconify-icon>
    </button>
  </div>
</nav>

<!-- Mobile Menu Overlay -->
<div id="mobileMenu" class="fixed inset-0 z-[60] bg-white/95 backdrop-blur-lg hidden flex-col items-center justify-center gap-8">
  <button id="mobileMenuClose" class="absolute top-5 right-6 w-10 h-10 flex items-center justify-center text-brand-text" aria-label="關閉">
    <iconify-icon icon="solar:close-circle-linear" class="text-3xl"></iconify-icon>
  </button>
  <a href="/#about" class="mobile-nav-link font-heading text-2xl text-brand-text hover:text-brand-accent transition-colors">關於我</a>
  <a href="/#portfolio" class="mobile-nav-link font-heading text-2xl text-brand-text hover:text-brand-accent transition-colors">作品集</a>
  <a href="/#articles" class="mobile-nav-link font-heading text-2xl text-brand-text hover:text-brand-accent transition-colors">文章</a>
  <a href="/#contact" class="mobile-nav-link font-heading text-2xl text-brand-text hover:text-brand-accent transition-colors">聯繫</a>
  <a href="/#contact" class="mag-btn mt-4 px-8 py-4 bg-brand-accent text-white font-heading font-semibold rounded-full text-base">
    <span>開始合作</span>
  </a>
</div>

<script is:inline>
  document.getElementById('mobileMenuBtn')?.addEventListener('click', () => {
    const menu = document.getElementById('mobileMenu');
    menu.classList.remove('hidden');
    menu.classList.add('flex');
  });
  document.getElementById('mobileMenuClose')?.addEventListener('click', () => {
    const menu = document.getElementById('mobileMenu');
    menu.classList.add('hidden');
    menu.classList.remove('flex');
  });
  document.querySelectorAll('.mobile-nav-link').forEach(link => {
    link.addEventListener('click', () => {
      const menu = document.getElementById('mobileMenu');
      menu.classList.add('hidden');
      menu.classList.remove('flex');
    });
  });
</script>

<!-- Page Content -->
<slot />

<!-- Footer -->
<footer class="py-12 border-t border-brand-light-border relative z-10 bg-brand-dark">
  <div class="site-container px-6">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="font-heading font-bold text-sm tracking-widest text-brand-accent">ANGELA<span class="text-white">.JIAN</span></div>
      <p class="text-xs text-gray-400 font-body">&copy; 2026 Angela Jian. Crafted with passion & pixels.</p>
      <div class="flex items-center gap-1 text-xs text-gray-400 font-body">
        <span>Built with</span>
        <iconify-icon icon="solar:heart-bold" class="text-red-400"></iconify-icon>
        <span>and</span>
        <iconify-icon icon="solar:cup-hot-bold" class="text-brand-accent"></iconify-icon>
      </div>
    </div>
  </div>
</footer>

<!-- Global Scripts -->
<script is:inline src="/scripts/main.js"></script>

<!-- Debug: find overflow elements (remove after fixing) -->
<script is:inline>
document.addEventListener('DOMContentLoaded', function() {
  var docWidth = document.documentElement.offsetWidth;
  var all = document.querySelectorAll('*');
  var overflows = [];
  all.forEach(function(el) {
    var rect = el.getBoundingClientRect();
    if (rect.right > docWidth + 1) {
      overflows.push({
        tag: el.tagName,
        id: el.id,
        class: el.className.toString().slice(0, 80),
        right: Math.round(rect.right),
        width: Math.round(rect.width),
        docWidth: docWidth
      });
    }
  });
  if (overflows.length) {
    console.log('=== OVERFLOW ELEMENTS ===');
    overflows.forEach(function(o) { console.log(o); });
  }
});
</script>

</body>
</html>
