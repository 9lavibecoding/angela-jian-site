---
import Base from '../../layouts/Base.astro';
import { getArticles } from '../../lib/notion';

const articles = await getArticles();

const tagStyles: Record<string, string> = {
  accent: 'bg-brand-accent/10 text-brand-accent-dark',
  warm:   'bg-brand-warm-dark/10 text-brand-warm-dark',
  cool:   'bg-brand-cool/10 text-brand-cool',
  purple: 'bg-purple-600/10 text-purple-600',
};

const cardHeaderStyles: Record<string, { bg: string; icon: string }> = {
  accent: { bg: 'bg-amber-100/60',  icon: 'solar:document-text-bold' },
  warm:   { bg: 'bg-amber-100/60',   icon: 'solar:lightbulb-bolt-bold' },
  cool:   { bg: 'bg-slate-100/60',   icon: 'solar:chart-2-bold' },
  purple: { bg: 'bg-purple-100/60',  icon: 'solar:settings-bold' },
};

const featuredArticles = articles.slice(0, 2);
const moreArticles = articles.slice(2, 6);
---

<Base title="AI PM INSIDER — The AI Transformation Guide for Product Managers" lang="en">

<!-- FAQ Schema for SEO -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Who is Angela Jian?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A senior product manager and AI product builder with 8+ years of mobile app growth and monetization experience, having scaled products from 0 to 600K MAU. She also runs the 'AI Product Thinking Lab' and holds the MOEA AI Application Planner certification."
      }
    },
    {
      "@type": "Question",
      "name": "What is AI PM INSIDER?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "AI PM INSIDER is Angela Jian's personal website and blog, sharing AI product management, product growth strategies, and monetization insights to help product professionals build AI-era product thinking."
      }
    },
    {
      "@type": "Question",
      "name": "How does an AI Product Manager differ from a traditional PM?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Beyond the user insights and project management skills of a traditional PM, an AI PM needs to understand AI model capabilities and limitations, how data quality impacts products, and how to design human-AI collaborative product experiences."
      }
    },
    {
      "@type": "Question",
      "name": "How do you acquire the first users during a cold start?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The key is finding your Minimum Viable Audience (MVA), rapidly validating product value through targeted community engagement, content marketing, or strategic partnerships, then iterating on product and acquisition strategies using data feedback."
      }
    },
    {
      "@type": "Question",
      "name": "How can I work with Angela Jian?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Feel free to reach out via the website contact form or LinkedIn to discuss product strategy consulting, AI product planning, or team training opportunities."
      }
    },
    {
      "@type": "Question",
      "name": "How can mobile apps effectively integrate AI features?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Start from user pain points, prioritize scenarios where AI clearly enhances the experience (e.g., personalized recommendations, smart search), launch an MVP quickly to validate results, and avoid adding AI for AI's sake."
      }
    }
  ]
})} />

<!-- HERO SECTION — Content Brand First -->
<section class="relative overflow-hidden" id="hero" style="background: #FFFEF7;">
  <div class="site-container px-6 pt-28 md:pt-36 pb-16 md:pb-20 relative z-10">

    <div class="flex flex-col-reverse md:flex-row items-center gap-8 md:gap-16">

      <!-- Left: Text Content -->
      <div class="flex-1 text-center md:text-left">
        <h1 class="hero-title text-4xl md:text-[3.5rem] lg:text-[4.2rem] mb-6 text-brand-text leading-tight">
          <span class="line"><span class="line-inner">The</span></span>
          <span class="line"><span class="line-inner"><span class="text-brand-accent">AI Transformation</span> Guide</span></span>
          <span class="line"><span class="line-inner">for Product Managers</span></span>
        </h1>

        <p class="font-body text-brand-subtle text-base md:text-lg leading-relaxed mb-6 opacity-0 max-w-lg mx-auto md:mx-0" id="heroDesc">
          From AI product strategy to hands-on tools and career pivots — firsthand insights from a senior PM.
        </p>

        <div class="flex flex-wrap gap-2 mb-8 opacity-0 justify-center md:justify-start" id="heroTags">
          <span class="px-3 py-1.5 text-xs font-body rounded-full bg-amber-50 text-brand-accent-dark">#AI Product Management</span>
          <span class="px-3 py-1.5 text-xs font-body rounded-full bg-amber-50 text-brand-warm-dark">#PM Tools in Action</span>
          <span class="px-3 py-1.5 text-xs font-body rounded-full bg-emerald-50 text-emerald-700">#Career Growth</span>
        </div>

        <div class="flex flex-wrap gap-4 opacity-0 justify-center md:justify-start" id="heroCTAs">
          <a href="#articles" class="mag-btn px-6 md:px-8 py-3.5 md:py-4 gold-gradient text-white font-heading font-semibold rounded-full text-sm tracking-wide">
            <span>Start Reading</span>
          </a>
          <a href="#about" class="mag-btn px-6 md:px-8 py-3.5 md:py-4 border border-brand-light-border text-brand-text font-heading font-medium rounded-full text-sm tracking-wide hover:border-brand-accent hover:text-brand-accent transition-colors">
            <span>About the Author</span>
          </a>
        </div>
      </div>

      <!-- Right: Dual Circle — Brand + Author -->
      <div class="relative flex justify-center md:justify-end shrink-0 w-52 h-52 md:w-64 md:h-64 lg:w-72 lg:h-72">
        <!-- Brand circle (top-left) -->
        <div class="absolute top-0 left-0 w-36 h-36 md:w-44 md:h-44 lg:w-48 lg:h-48 rounded-full overflow-hidden shadow-lg">
          <img src="/logo.png" alt="AI PM INSIDER" class="w-full h-full object-cover" loading="eager">
        </div>
        <!-- Author photo (bottom-right, overlapping) -->
        <div class="absolute bottom-0 right-0">
          <div class="w-36 h-36 md:w-44 md:h-44 lg:w-48 lg:h-48 rounded-full overflow-hidden ring-4 ring-white shadow-xl">
            <img src="/angela.jpeg" alt="Angela Jian"
                 class="w-full h-full object-cover" loading="eager">
          </div>
          <!-- Name badge -->
          <div class="absolute -bottom-5 left-1/2 -translate-x-1/2 bg-white/90 backdrop-blur-sm border border-brand-light-border rounded-full px-4 py-1.5 shadow-sm whitespace-nowrap">
            <span class="font-heading font-semibold text-xs text-brand-text">Angela Jian</span>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- FEATURED ARTICLES — Main Content Area -->
<section class="relative py-16 md:py-24 overflow-hidden bg-white" id="articles">
  <div class="site-container px-6 relative z-10">

    <div class="flex items-center justify-between mb-8 flex-wrap gap-4">
      <div>
        <div class="flex items-center gap-3 text-brand-subtle text-xs tracking-widest font-body uppercase mb-4">
          <div class="w-8 h-px bg-brand-accent"></div>
          <span>Latest Articles</span>
        </div>
        <h2 class="font-heading font-black text-3xl md:text-5xl text-brand-text">
          Featured <span class="text-brand-accent">Articles</span>
        </h2>
      </div>
      <a href="/articles" class="mag-btn px-4 md:px-6 py-2 md:py-3 border border-brand-light-border text-brand-subtle font-body text-xs md:text-sm rounded-full hover:text-brand-accent hover:border-brand-accent transition-colors no-underline shrink-0">
        <span>View All</span>
      </a>
    </div>

    <!-- 2 Featured Large Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
      {featuredArticles.map((article, i) => {
        const header = cardHeaderStyles[article.tagColors[0]] || cardHeaderStyles.accent;
        return (
          <a href={`/articles/${article.slug}`}
             class="card-hover rounded-2xl bg-white border border-brand-light-border block overflow-hidden group no-underline"
             data-stagger={i}>
            <div class={`${header.bg} flex items-center justify-center py-10 md:py-14`}>
              <iconify-icon icon={header.icon} class="text-5xl md:text-6xl text-brand-text/15 group-hover:text-brand-text/30 transition-colors"></iconify-icon>
            </div>
            <div class="p-5 md:p-6">
              <div class="flex items-center gap-2 mb-3 flex-wrap">
                {article.tags.map((tag, j) => (
                  <span class={`px-2.5 py-1 text-[11px] rounded-full font-body ${tagStyles[article.tagColors[j]] || tagStyles.accent}`}>{tag}</span>
                ))}
                <span class="text-[11px] text-brand-subtle font-body">{article.date}</span>
              </div>
              <h3 class="font-heading font-bold text-lg md:text-xl mb-2 leading-snug text-brand-text">{article.title}</h3>
              {article.summary && (
                <p class="text-sm text-brand-subtle leading-relaxed line-clamp-3">{article.summary}</p>
              )}
            </div>
          </a>
        );
      })}
    </div>

    <!-- More Articles — Smaller Cards -->
    {moreArticles.length > 0 && (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {moreArticles.map((article, i) => {
          return (
            <a href={`/articles/${article.slug}`}
               class="card-hover rounded-xl bg-white border border-brand-light-border block overflow-hidden group no-underline p-4 md:p-5"
               data-stagger={i + 2}>
              <div class="flex items-center gap-2 mb-2 flex-wrap">
                {article.tags.slice(0, 1).map((tag, j) => (
                  <span class={`px-2 py-0.5 text-[10px] rounded-full font-body ${tagStyles[article.tagColors[j]] || tagStyles.accent}`}>{tag}</span>
                ))}
              </div>
              <h4 class="font-heading font-semibold text-sm mb-1.5 leading-snug text-brand-text line-clamp-2">{article.title}</h4>
              <span class="text-[11px] text-brand-subtle font-body">{article.date}</span>
            </a>
          );
        })}
      </div>
    )}

  </div>
</section>

<!-- NEWSLETTER CTA — Standalone Section -->
<section class="relative py-16 md:py-20 overflow-hidden" id="newsletter" style="background: linear-gradient(135deg, #1a1814 0%, #2a2520 50%, #1a1814 100%);">
  <div class="site-container px-6 relative z-10 text-center">
    <iconify-icon icon="solar:letter-bold" class="text-brand-accent text-3xl md:text-4xl mb-4"></iconify-icon>
    <h2 class="font-heading font-black text-2xl md:text-3xl text-white mb-3">AI Applied Playbook</h2>
    <p class="text-sm md:text-base text-gray-400 font-body mb-2">Weekly AI product insights from the trenches</p>
    <p class="text-xs md:text-sm text-[#D4B86A]/70 font-body mb-8 italic">"Turning AI from a tool into a workflow — the practical playbook"</p>
    <a href="https://www.linkedin.com/newsletters/ai-applied-playbook%EF%BD%9Caipm-%E6%80%9D%E7%B6%AD%E5%AF%A6%E9%A9%97%E5%AE%A4-7402251966258720768" target="_blank" class="mag-btn px-8 py-3.5 gold-gradient text-white font-heading font-semibold rounded-full text-sm tracking-wide inline-flex no-underline">
      <span>Subscribe Free</span>
    </a>
  </div>
</section>

<!-- ABOUT SECTION — Simplified -->
<section class="relative py-20 md:py-28 overflow-hidden bg-white" id="about">
  <div class="site-container px-6 relative z-10">

    <div class="flex flex-col md:flex-row items-center gap-10 md:gap-16">

      <!-- Left: Photo -->
      <div class="shrink-0">
        <div class="w-52 md:w-72 rounded-2xl overflow-hidden shadow-lg">
          <img src="/angela.jpeg" alt="Angela Jian"
               class="w-full aspect-[3/4] object-cover" loading="lazy">
        </div>
      </div>

      <!-- Right: Content -->
      <div class="flex-1 text-center md:text-left">
        <div class="flex items-center gap-3 text-brand-subtle text-xs tracking-widest font-body uppercase mb-4 justify-center md:justify-start">
          <div class="w-8 h-px bg-brand-accent"></div>
          <span>About the Author</span>
        </div>
        <h2 class="font-heading font-black text-3xl md:text-4xl leading-tight text-brand-text mb-5">
          Hi, I'm <span class="text-brand-accent">Angela</span>
        </h2>
        <p class="text-sm md:text-base font-body text-brand-subtle leading-relaxed mb-4">
          Senior Product Manager with 8+ years of experience in mobile app growth and monetization. I've scaled products from zero to 600K MAU and led core feature planning at high-growth companies including TikTok and LiveIn.
        </p>
        <p class="text-sm md:text-base font-body text-brand-subtle leading-relaxed mb-6">
          Now focused on AI product strategy, I also run the "AI Product Thinking Lab," sharing the mindsets and tools product professionals need in the age of AI.
        </p>
        <div class="flex flex-wrap gap-2 justify-center md:justify-start">
          <span class="px-3 py-1.5 text-[11px] font-body rounded-full bg-brand-accent/10 text-brand-accent-dark">8+ Years PM</span>
          <span class="px-3 py-1.5 text-[11px] font-body rounded-full bg-brand-accent/10 text-brand-accent-dark">MAU 600K</span>
          <span class="px-3 py-1.5 text-[11px] font-body rounded-full bg-purple-600/10 text-purple-600">AI Application Planner Cert.</span>
          <span class="px-3 py-1.5 text-[11px] font-body rounded-full bg-brand-warm-dark/10 text-brand-warm-dark">Revenue +120%</span>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- PORTFOLIO SECTION — Compact -->
<section class="relative py-20 md:py-28 overflow-hidden" id="portfolio" style="background: #FAF6EF;">
  <div class="site-container px-6 relative z-10">

    <div class="flex items-center gap-3 text-brand-subtle text-xs tracking-widest font-body uppercase mb-4 md:mb-6">
      <div class="w-8 h-px bg-brand-accent"></div>
      <span>Selected Works</span>
    </div>
    <h2 class="font-heading font-black text-3xl md:text-4xl mb-8 md:mb-10 text-brand-text">
      AI <span class="text-brand-accent">Portfolio</span>
    </h2>

    <!-- Single Row Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">

      <a href="/en/portfolio/ai-competitive-dashboard" class="group block p-5 md:p-6 bg-white border border-brand-light-border rounded-xl hover:shadow-md transition-all duration-300 no-underline">
        <span class="text-2xl font-heading font-light italic text-brand-accent/20 block mb-3">01</span>
        <h3 class="font-heading font-bold text-base text-brand-text mb-2 group-hover:text-brand-accent transition-colors">AI Competitive Intelligence Dashboard</h3>
        <p class="text-xs text-brand-subtle leading-relaxed">Real-time competitor tracking with OpenAI + Supabase</p>
      </a>

      <a href="/en/portfolio/human-in-the-loop-accounting" class="group block p-5 md:p-6 bg-white border border-brand-light-border rounded-xl hover:shadow-md transition-all duration-300 no-underline">
        <span class="text-2xl font-heading font-light italic text-brand-accent/20 block mb-3">02</span>
        <h3 class="font-heading font-bold text-base text-brand-text mb-2 group-hover:text-brand-accent transition-colors">Human-in-the-Loop AI Accounting</h3>
        <p class="text-xs text-brand-subtle leading-relaxed">Automated bookkeeping, 97% accuracy</p>
      </a>

      <a href="/en/portfolio/prompt-generator" class="group block p-5 md:p-6 bg-white border border-brand-light-border rounded-xl hover:shadow-md transition-all duration-300 no-underline">
        <span class="text-2xl font-heading font-light italic text-brand-accent/20 block mb-3">03</span>
        <h3 class="font-heading font-bold text-base text-brand-text mb-2 group-hover:text-brand-accent transition-colors">AI Prompt Template Generator</h3>
        <p class="text-xs text-brand-subtle leading-relaxed">One-click prompt generation for 5 PM scenarios</p>
      </a>

      <a href="/en/portfolio/ai-pm-assessment" class="group block p-5 md:p-6 bg-white border border-brand-light-border rounded-xl hover:shadow-md transition-all duration-300 no-underline">
        <span class="text-2xl font-heading font-light italic text-brand-accent/20 block mb-3">04</span>
        <h3 class="font-heading font-bold text-base text-brand-text mb-2 group-hover:text-brand-accent transition-colors">PM → AI PM Readiness Quiz</h3>
        <p class="text-xs text-brand-subtle leading-relaxed">Interactive self-assessment with learning paths</p>
      </a>

    </div>

  </div>
</section>

<!-- CONTACT SECTION -->
<section class="relative py-20 md:py-28 overflow-hidden" id="contact" style="background: linear-gradient(135deg, #1a1814 0%, #2a2520 50%, #1a1814 100%);">
  <div class="site-container px-6 relative z-10">
    <div class="max-w-4xl mx-auto text-center">
      <div class="flex items-center justify-center gap-3 text-gray-400 text-xs tracking-widest font-body uppercase mb-6 md:mb-8">
        <div class="w-8 h-px bg-brand-accent"></div>
        <span>Contact</span>
        <div class="w-8 h-px bg-brand-accent"></div>
      </div>

      <h2 class="font-heading font-black text-3xl md:text-7xl lg:text-8xl mb-6 md:mb-8 leading-tight text-white">
        Let's<br><span class="text-brand-accent">Connect</span>
      </h2>

      <p class="text-base md:text-lg text-gray-400 font-body max-w-2xl mx-auto mb-8 md:mb-12 leading-relaxed">
        Looking for a product partner who thinks clearly and ships effectively? Let's chat.
      </p>

      <div class="flex justify-center mb-10 md:mb-16">
        <a href="mailto:an9lajian@gmail.com" class="mag-btn px-8 md:px-10 py-3.5 md:py-5 gold-gradient text-white font-heading font-bold rounded-full text-sm md:text-base tracking-wide text-center no-underline">
          <span>Get in Touch</span>
        </a>
      </div>

      <div class="flex items-center justify-center gap-6">
        <a href="https://www.linkedin.com/in/angela-jian/" target="_blank" class="w-12 h-12 rounded-full border border-gray-600 flex items-center justify-center text-gray-400 hover:text-brand-accent hover:border-brand-accent transition-all duration-300">
          <iconify-icon icon="simple-icons:linkedin" class="text-xl"></iconify-icon>
        </a>
        <a href="mailto:an9lajian@gmail.com" class="w-12 h-12 rounded-full border border-gray-600 flex items-center justify-center text-gray-400 hover:text-brand-accent hover:border-brand-accent transition-all duration-300">
          <iconify-icon icon="solar:letter-bold" class="text-xl"></iconify-icon>
        </a>
      </div>
    </div>
  </div>
</section>

</Base>
