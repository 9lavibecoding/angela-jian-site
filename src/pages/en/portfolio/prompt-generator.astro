---
import Base from '../../../layouts/Base.astro';
---

<Base title="AI Prompt Template Generator — Angela Jian" description="Choose your work scenario and get a customized structured prompt generated by AI in real time. Five common PM templates: competitive analysis, PRD writing, user interview synthesis, data analysis, and weekly report." lang="en">

<main class="pt-28 pb-20 min-h-screen bg-[#FFFEF7]">
  <div class="site-container px-6">

    <!-- Header -->
    <div class="mb-12">
      <a href="/en/#portfolio" class="inline-flex items-center gap-2 text-brand-subtle hover:text-brand-accent transition-colors duration-300 font-body text-sm mb-6 group">
        <iconify-icon icon="solar:arrow-left-linear" class="text-lg transition-transform duration-300 group-hover:-translate-x-1"></iconify-icon>
        <span>Back to Portfolio</span>
      </a>
      <h1 class="font-heading font-bold text-3xl md:text-4xl text-brand-text mt-4">AI Prompt Template Generator</h1>
      <p class="font-body text-brand-subtle mt-3 text-base md:text-lg">Choose your work scenario, get a customized prompt generated by AI</p>
    </div>

    <!-- Scene Selector Cards -->
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-4 mb-10" id="sceneCards">
      <button data-scene="competitive" class="scene-card group flex flex-col items-center gap-3 p-5 rounded-2xl border-2 border-brand-light-border bg-white cursor-pointer transition-all duration-300 hover:border-brand-accent hover:shadow-lg hover:-translate-y-1">
        <iconify-icon icon="solar:chart-2-bold" class="text-3xl text-brand-subtle group-hover:text-brand-accent transition-colors duration-300"></iconify-icon>
        <span class="font-body text-sm font-medium text-brand-text text-center">Competitive Analysis</span>
      </button>
      <button data-scene="prd" class="scene-card group flex flex-col items-center gap-3 p-5 rounded-2xl border-2 border-brand-light-border bg-white cursor-pointer transition-all duration-300 hover:border-brand-accent hover:shadow-lg hover:-translate-y-1">
        <iconify-icon icon="solar:document-text-bold" class="text-3xl text-brand-subtle group-hover:text-brand-accent transition-colors duration-300"></iconify-icon>
        <span class="font-body text-sm font-medium text-brand-text text-center">PRD Writing</span>
      </button>
      <button data-scene="interview" class="scene-card group flex flex-col items-center gap-3 p-5 rounded-2xl border-2 border-brand-light-border bg-white cursor-pointer transition-all duration-300 hover:border-brand-accent hover:shadow-lg hover:-translate-y-1">
        <iconify-icon icon="solar:users-group-rounded-bold" class="text-3xl text-brand-subtle group-hover:text-brand-accent transition-colors duration-300"></iconify-icon>
        <span class="font-body text-sm font-medium text-brand-text text-center">User Interview Synthesis</span>
      </button>
      <button data-scene="data" class="scene-card group flex flex-col items-center gap-3 p-5 rounded-2xl border-2 border-brand-light-border bg-white cursor-pointer transition-all duration-300 hover:border-brand-accent hover:shadow-lg hover:-translate-y-1">
        <iconify-icon icon="solar:graph-new-bold" class="text-3xl text-brand-subtle group-hover:text-brand-accent transition-colors duration-300"></iconify-icon>
        <span class="font-body text-sm font-medium text-brand-text text-center">Data Analysis</span>
      </button>
      <button data-scene="weekly" class="scene-card group flex flex-col items-center gap-3 p-5 rounded-2xl border-2 border-brand-light-border bg-white cursor-pointer transition-all duration-300 hover:border-brand-accent hover:shadow-lg hover:-translate-y-1">
        <iconify-icon icon="solar:calendar-bold" class="text-3xl text-brand-subtle group-hover:text-brand-accent transition-colors duration-300"></iconify-icon>
        <span class="font-body text-sm font-medium text-brand-text text-center">Weekly Report</span>
      </button>
    </div>

    <!-- Context Input Area -->
    <div id="contextInputArea" class="opacity-0 translate-y-4 transition-all duration-500 ease-out mb-8" style="display:none;">
      <div class="bg-white rounded-2xl border border-brand-light-border shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-brand-light-border bg-gray-50/60">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
              <iconify-icon icon="solar:pen-new-round-bold" class="text-brand-accent text-lg"></iconify-icon>
              <span class="font-heading font-semibold text-sm text-brand-text" id="contextLabel">Enter your specific context</span>
            </div>
            <span id="usageCounter" class="font-body text-xs text-brand-subtle bg-gray-100 px-3 py-1 rounded-full">Remaining: --/50</span>
          </div>
        </div>
        <div class="p-6">
          <textarea
            id="contextInput"
            class="w-full font-body text-sm md:text-base text-brand-text bg-gray-50/50 border border-brand-light-border rounded-xl px-4 py-3 resize-none overflow-hidden focus:outline-none focus:border-brand-accent focus:ring-2 focus:ring-brand-accent/20 transition-all duration-200 placeholder:text-brand-subtle/60"
            rows="3"
            placeholder=""
          ></textarea>
          <div class="flex items-center justify-between mt-4">
            <p class="font-body text-xs text-brand-subtle">AI will generate a customized prompt based on your context</p>
            <button
              id="generateBtn"
              class="inline-flex items-center gap-2 px-6 py-2.5 rounded-full gold-gradient text-white text-sm font-body font-medium hover:opacity-90 transition-all duration-200 cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed"
            >
              <iconify-icon icon="solar:magic-stick-3-bold" class="text-base" id="generateIcon"></iconify-icon>
              <span id="generateBtnText">Generate Prompt</span>
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Loading State -->
    <div id="loadingState" class="hidden mb-8">
      <div class="bg-white rounded-2xl border border-brand-light-border shadow-sm p-10 flex flex-col items-center justify-center gap-4">
        <div class="loading-dots flex items-center gap-2">
          <span class="dot"></span>
          <span class="dot"></span>
          <span class="dot"></span>
        </div>
        <p class="font-body text-sm text-brand-subtle">AI is generating your customized prompt...</p>
      </div>
    </div>

    <!-- Output Box -->
    <div id="outputWrapper" class="opacity-0 translate-y-4 transition-all duration-500 ease-out" style="display:none;">
      <div class="bg-white rounded-2xl border border-brand-light-border shadow-sm overflow-hidden">
        <!-- Output Header -->
        <div class="flex items-center justify-between px-6 py-4 border-b border-brand-light-border bg-gray-50/60">
          <div class="flex items-center gap-2">
            <iconify-icon icon="solar:magic-stick-3-bold" class="text-brand-accent text-lg"></iconify-icon>
            <span class="font-heading font-semibold text-sm text-brand-text" id="outputTitle">Generated Prompt</span>
            <span id="outputBadge" class="hidden font-body text-xs px-2 py-0.5 rounded-full bg-amber-100 text-amber-700 border border-amber-200">Static Template</span>
          </div>
          <button id="copyBtn" class="inline-flex items-center gap-2 px-4 py-2 rounded-full gold-gradient text-white text-sm font-body font-medium hover:opacity-90 transition-opacity duration-200 cursor-pointer">
            <iconify-icon icon="solar:copy-bold" class="text-base"></iconify-icon>
            <span>Copy Prompt</span>
          </button>
        </div>
        <!-- Output Content -->
        <div class="p-6">
          <pre id="outputContent" class="font-body text-sm md:text-base text-brand-text whitespace-pre-wrap leading-relaxed"></pre>
        </div>
      </div>
      <!-- Error fallback note -->
      <p id="fallbackNote" class="hidden font-body text-xs text-amber-600 mt-3 px-2">AI generation is temporarily unavailable. A static template is shown instead. You can customize it by editing the content in [ ] brackets.</p>
    </div>

    <!-- Tip -->
    <div class="mt-10 p-5 rounded-xl bg-amber-50/60 border border-amber-200">
      <p class="font-body text-sm text-brand-subtle leading-relaxed">
        <span class="font-medium text-brand-text">Pro tip:</span> The more specific your context, the better the AI-generated prompt. For example: specify the industry, target users, specific features, and other details.
      </p>
    </div>

  </div>
</main>

<!-- Toast -->
<div id="toast" class="fixed bottom-8 left-1/2 -translate-x-1/2 z-50 px-6 py-3 rounded-full gold-gradient text-white font-body text-sm font-medium shadow-lg opacity-0 pointer-events-none transition-all duration-300 translate-y-4">
  Copied!
</div>

<style>
  .scene-card.active {
    border-color: var(--color-brand-accent, #C5A55A) !important;
    background: linear-gradient(135deg, rgba(197,165,90,0.04), rgba(197,165,90,0.08));
    box-shadow: 0 4px 24px rgba(197,165,90,0.15);
    transform: translateY(-2px);
  }
  .scene-card.active iconify-icon {
    color: var(--color-brand-accent, #C5A55A) !important;
  }
  .scene-card.active span {
    color: var(--color-brand-accent, #C5A55A) !important;
  }
  #outputContent {
    font-family: 'Inter', sans-serif;
  }
  #contextInput {
    min-height: 80px;
    font-family: 'Inter', sans-serif;
  }

  /* Loading dots animation */
  .loading-dots .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: var(--color-brand-accent, #C5A55A);
    animation: dotPulse 1.4s ease-in-out infinite;
  }
  .loading-dots .dot:nth-child(2) {
    animation-delay: 0.2s;
  }
  .loading-dots .dot:nth-child(3) {
    animation-delay: 0.4s;
  }
  @keyframes dotPulse {
    0%, 80%, 100% {
      opacity: 0.3;
      transform: scale(0.8);
    }
    40% {
      opacity: 1;
      transform: scale(1.1);
    }
  }

  /* Spinner for generate button */
  .btn-spinner {
    display: inline-block;
    width: 16px;
    height: 16px;
    border: 2px solid rgba(255,255,255,0.3);
    border-top-color: #fff;
    border-radius: 50%;
    animation: spin 0.6s linear infinite;
  }
  @keyframes spin {
    to { transform: rotate(360deg); }
  }
</style>

<script is:inline>
(function() {
  var templates = {
    competitive: {
      title: 'Competitive Analysis Prompt',
      content: "[Role] You are a senior B2B SaaS product analyst.\n\n[Task] Please compare the following competitors: [Enter competitor names]\n\n[Analysis Dimensions]\n1. Target users & market positioning\n2. Core features & differentiation\n3. Pricing strategy & business model\n4. Key strengths & weaknesses\n5. Recent major updates or developments\n\n[Output Format]\n- Present each dimension in a comparison table\n- Include a 200-word observation summary at the end\n- Note the timeliness and reliability of information"
    },
    prd: {
      title: 'PRD Writing Prompt',
      content: "[Role] You are a product manager with 10 years of experience.\n\n[Task] Please draft a PRD for the following feature: [Enter feature description]\n\n[Include]\n1. Feature Overview\n2. User Stories \u2014 at least 5\n3. Acceptance Criteria\n4. Edge Cases \u2014 at least 8\n5. Glossary\n\n[Output Format]\n- Use clear heading hierarchy\n- User Story format: As a [role], I want [goal], so that [value]\n- Edge Cases sorted by severity"
    },
    interview: {
      title: 'User Interview Synthesis Prompt',
      content: "[Role] You are a senior user researcher.\n\n[Task] Please synthesize the following user interview transcript: [Paste transcript here]\n\n[Synthesis Dimensions]\n1. User background summary\n2. Key pain points (sorted by severity)\n3. Evaluation of existing solutions\n4. Notable verbatim quotes\n5. Unmet needs\n6. Suggested follow-up actions\n\n[Output Format]\n- Attach supporting verbatim quotes to each pain point\n- Use \uD83D\uDD34\uD83D\uDFE1\uD83D\uDFE2 to indicate pain point severity\n- Include an overall insight summary at the end"
    },
    data: {
      title: 'Data Analysis Prompt',
      content: "[Role] You are a senior data analyst.\n\n[Task] Please analyze the following data: [Describe your data or upload file]\n\n[Analysis Requirements]\n1. List the top 5 interesting patterns or anomalies\n2. For each pattern explain:\n   - What you observed\n   - Possible causal hypotheses\n   - Suggested directions for further validation\n3. Note your Confidence Level (High/Medium/Low)\n\n[Output Format]\n- Present in tables or bullet points\n- High-confidence findings first\n- Include a \"Suggested Next Steps\" list at the end"
    },
    weekly: {
      title: 'Weekly Report Prompt',
      content: "[Role] You are an assistant to a senior product manager.\n\n[Task] Please generate this week's report based on the following information: [Paste your weekly work content]\n\n[Report Structure]\n1. Top 3 key accomplishments this week\n2. Ongoing project status updates\n3. Blockers encountered & solutions\n4. Next week's plan & priorities\n5. Items needing assistance or decisions\n\n[Output Format]\n- Keep each section to 3-5 lines\n- Use \u2705 \uD83D\uDD04 \u26A0\uFE0F to indicate status\n- Professional but not stiff tone\n- Total length under 500 words"
    }
  };

  var placeholders = {
    competitive: 'Enter the competitor names and industry to analyze (e.g., Notion, Coda, Airtable \u2014 project management tools)',
    prd: 'Describe the feature you want to write a PRD for (e.g., an AI product recommendation feature for an e-commerce platform based on browsing history)',
    interview: 'Paste the interview transcript or describe the interviewee and topic',
    data: 'Describe your data and analysis goals (e.g., 6 months of user activity data, looking for reasons behind retention drop)',
    weekly: 'Briefly describe your main work this week'
  };

  var contextLabels = {
    competitive: 'Enter the competitors you want to analyze',
    prd: 'Describe the feature for your PRD',
    interview: 'Paste interview content or describe the background',
    data: 'Describe your data and analysis goals',
    weekly: 'Briefly describe your main work this week'
  };

  var cards = document.querySelectorAll('.scene-card');
  var contextInputArea = document.getElementById('contextInputArea');
  var contextInput = document.getElementById('contextInput');
  var contextLabel = document.getElementById('contextLabel');
  var generateBtn = document.getElementById('generateBtn');
  var generateBtnText = document.getElementById('generateBtnText');
  var generateIcon = document.getElementById('generateIcon');
  var loadingState = document.getElementById('loadingState');
  var outputWrapper = document.getElementById('outputWrapper');
  var outputTitle = document.getElementById('outputTitle');
  var outputContent = document.getElementById('outputContent');
  var outputBadge = document.getElementById('outputBadge');
  var fallbackNote = document.getElementById('fallbackNote');
  var copyBtn = document.getElementById('copyBtn');
  var toast = document.getElementById('toast');
  var usageCounter = document.getElementById('usageCounter');

  var currentScene = null;
  var isGenerating = false;

  // Auto-grow textarea
  contextInput.addEventListener('input', function() {
    this.style.height = 'auto';
    this.style.height = this.scrollHeight + 'px';
  });

  // Scene card selection
  cards.forEach(function(card) {
    card.addEventListener('click', function() {
      var scene = this.getAttribute('data-scene');
      currentScene = scene;

      // Update active state
      cards.forEach(function(c) { c.classList.remove('active'); });
      this.classList.add('active');

      // Hide output if visible
      outputWrapper.style.display = 'none';
      outputWrapper.classList.add('opacity-0', 'translate-y-4');
      outputWrapper.classList.remove('opacity-100', 'translate-y-0');

      // Hide loading
      loadingState.classList.add('hidden');

      // Show context input area
      contextLabel.textContent = contextLabels[scene] || 'Enter your specific context';
      contextInput.placeholder = placeholders[scene] || '';
      contextInput.value = '';
      contextInput.style.height = 'auto';

      contextInputArea.style.display = 'block';
      void contextInputArea.offsetHeight;
      contextInputArea.classList.remove('opacity-0', 'translate-y-4');
      contextInputArea.classList.add('opacity-100', 'translate-y-0');

      // Reset button state
      generateBtn.disabled = false;
      generateBtnText.textContent = 'Generate Prompt';
      generateIcon.setAttribute('icon', 'solar:magic-stick-3-bold');
      generateIcon.classList.remove('btn-spinner');

      // Scroll to input area
      setTimeout(function() {
        contextInputArea.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }, 100);
    });
  });

  // Generate button click
  generateBtn.addEventListener('click', function() {
    if (isGenerating || !currentScene) return;

    var context = contextInput.value.trim();
    if (!context) {
      contextInput.focus();
      contextInput.classList.add('ring-2', 'ring-red-300', 'border-red-300');
      setTimeout(function() {
        contextInput.classList.remove('ring-2', 'ring-red-300', 'border-red-300');
      }, 1500);
      return;
    }

    generatePrompt(currentScene, context);
  });

  // Also allow Ctrl+Enter / Cmd+Enter to generate
  contextInput.addEventListener('keydown', function(e) {
    if ((e.metaKey || e.ctrlKey) && e.key === 'Enter') {
      e.preventDefault();
      generateBtn.click();
    }
  });

  function generatePrompt(scene, context) {
    isGenerating = true;

    // Update button to loading state
    generateBtn.disabled = true;
    generateBtnText.textContent = 'Generating...';
    generateIcon.removeAttribute('icon');
    generateIcon.classList.add('btn-spinner');

    // Show loading animation
    loadingState.classList.remove('hidden');

    // Hide previous output
    outputWrapper.style.display = 'none';
    outputWrapper.classList.add('opacity-0', 'translate-y-4');
    outputWrapper.classList.remove('opacity-100', 'translate-y-0');
    fallbackNote.classList.add('hidden');
    outputBadge.classList.add('hidden');

    fetch('/api/generate-prompt', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ scene: scene, context: context, lang: 'en' })
    })
    .then(function(res) {
      return res.json().then(function(data) {
        return { ok: res.ok, status: res.status, data: data };
      });
    })
    .then(function(result) {
      loadingState.classList.add('hidden');

      if (result.ok && result.data.prompt) {
        // Success: show AI-generated prompt
        showOutput(templates[scene].title, result.data.prompt, false);

        // Update usage counter
        if (typeof result.data.remaining === 'number') {
          usageCounter.textContent = 'Remaining: ' + result.data.remaining + '/50';
        }
      } else {
        // API error: fall back to static template
        console.warn('API error:', result.data.error);
        showOutput(templates[scene].title, templates[scene].content, true);
      }
    })
    .catch(function(err) {
      // Network error: fall back to static template
      console.warn('Network error:', err);
      loadingState.classList.add('hidden');
      showOutput(templates[scene].title, templates[scene].content, true);
    })
    .finally(function() {
      isGenerating = false;
      generateBtn.disabled = false;
      generateBtnText.textContent = 'Generate Prompt';
      generateIcon.classList.remove('btn-spinner');
      generateIcon.setAttribute('icon', 'solar:magic-stick-3-bold');
    });
  }

  function showOutput(title, content, isFallback) {
    outputTitle.textContent = title;
    outputContent.textContent = content;

    if (isFallback) {
      outputBadge.classList.remove('hidden');
      fallbackNote.classList.remove('hidden');
    } else {
      outputBadge.classList.add('hidden');
      fallbackNote.classList.add('hidden');
    }

    outputWrapper.style.display = 'block';
    void outputWrapper.offsetHeight;
    outputWrapper.classList.remove('opacity-0', 'translate-y-4');
    outputWrapper.classList.add('opacity-100', 'translate-y-0');

    setTimeout(function() {
      outputWrapper.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }, 100);
  }

  // Copy functionality
  copyBtn.addEventListener('click', function() {
    var text = outputContent.textContent;
    if (!text) return;

    navigator.clipboard.writeText(text).then(function() {
      showToast();
    }).catch(function() {
      var textarea = document.createElement('textarea');
      textarea.value = text;
      textarea.style.position = 'fixed';
      textarea.style.opacity = '0';
      document.body.appendChild(textarea);
      textarea.select();
      document.execCommand('copy');
      document.body.removeChild(textarea);
      showToast();
    });
  });

  function showToast() {
    toast.classList.remove('opacity-0', 'translate-y-4');
    toast.classList.add('opacity-100', 'translate-y-0');
    setTimeout(function() {
      toast.classList.add('opacity-0', 'translate-y-4');
      toast.classList.remove('opacity-100', 'translate-y-0');
    }, 2000);
  }
})();
</script>

</Base>
