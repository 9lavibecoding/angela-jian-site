---
import Base from '../../../layouts/Base.astro';
---

<Base title="AI PM Skills Assessment — Angela Jian" description="10 scenario-based questions to test your AI Product Manager skills. Get a personalized score and learning recommendations." lang="en">

<main class="pt-28 pb-20 min-h-screen bg-[#FFFEF7]">
  <div class="site-container px-6">

    <!-- Header with back link -->
    <div class="mb-8">
      <a href="/en/#portfolio" class="inline-flex items-center gap-2 text-sm font-body text-brand-subtle hover:text-brand-accent transition-colors mb-6">
        <iconify-icon icon="solar:arrow-left-linear"></iconify-icon>
        Back to Portfolio
      </a>
    </div>

    <!-- Quiz Container -->
    <div id="quizApp" class="max-w-3xl mx-auto">

      <!-- ==================== START SCREEN ==================== -->
      <div id="startScreen" class="text-center py-8">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-amber-50 text-brand-accent text-sm font-body font-medium mb-6">
          <iconify-icon icon="solar:document-text-bold"></iconify-icon>
          10 scenario questions / ~5 minutes
        </div>
        <h1 class="font-heading font-bold text-3xl md:text-4xl lg:text-5xl text-brand-text mb-4 leading-tight">AI PM Skills Assessment</h1>
        <p class="font-body text-brand-subtle text-base md:text-lg max-w-xl mx-auto mb-8 leading-relaxed">
          Real-world product scenarios testing your skills across four dimensions: Product Management, AI Literacy, Prompt Engineering, and Data Thinking.
        </p>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10 max-w-2xl mx-auto">
          <div class="bg-brand-light-surface rounded-xl p-4 border border-brand-light-border">
            <div class="w-9 h-9 rounded-lg bg-amber-100 flex items-center justify-center mx-auto mb-2">
              <iconify-icon icon="solar:clipboard-list-bold" class="text-lg text-brand-accent"></iconify-icon>
            </div>
            <p class="font-body text-xs text-brand-subtle">PM Fundamentals</p>
            <p class="font-heading font-bold text-sm text-brand-text">20 pts</p>
          </div>
          <div class="bg-brand-light-surface rounded-xl p-4 border border-brand-light-border">
            <div class="w-9 h-9 rounded-lg bg-violet-100 flex items-center justify-center mx-auto mb-2">
              <iconify-icon icon="solar:cpu-bolt-bold" class="text-lg text-violet-600"></iconify-icon>
            </div>
            <p class="font-body text-xs text-brand-subtle">AI Literacy</p>
            <p class="font-heading font-bold text-sm text-brand-text">30 pts</p>
          </div>
          <div class="bg-brand-light-surface rounded-xl p-4 border border-brand-light-border">
            <div class="w-9 h-9 rounded-lg bg-amber-100 flex items-center justify-center mx-auto mb-2">
              <iconify-icon icon="solar:chat-round-dots-bold" class="text-lg text-amber-600"></iconify-icon>
            </div>
            <p class="font-body text-xs text-brand-subtle">Prompt Eng.</p>
            <p class="font-heading font-bold text-sm text-brand-text">30 pts</p>
          </div>
          <div class="bg-brand-light-surface rounded-xl p-4 border border-brand-light-border">
            <div class="w-9 h-9 rounded-lg bg-emerald-100 flex items-center justify-center mx-auto mb-2">
              <iconify-icon icon="solar:database-bold" class="text-lg text-emerald-600"></iconify-icon>
            </div>
            <p class="font-body text-xs text-brand-subtle">Data Thinking</p>
            <p class="font-heading font-bold text-sm text-brand-text">20 pts</p>
          </div>
        </div>

        <button id="startBtn" class="mag-btn inline-flex px-10 py-4 gold-gradient text-white font-heading font-semibold rounded-full text-base tracking-wide hover:opacity-90 transition-opacity">
          <span>Start Assessment</span>
        </button>
      </div>

      <!-- ==================== QUESTION SCREEN ==================== -->
      <div id="questionScreen" class="hidden">

        <!-- Progress Bar -->
        <div class="mb-6">
          <div class="flex items-center justify-between mb-2">
            <span id="progressLabel" class="font-body text-sm text-brand-subtle">Question 1 / 10</span>
            <span id="categoryBadge" class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-body font-medium"></span>
          </div>
          <div class="w-full h-2 bg-gray-100 rounded-full overflow-hidden">
            <div id="progressBar" class="h-full bg-brand-accent rounded-full transition-all duration-500 ease-out" style="width: 10%"></div>
          </div>
        </div>

        <!-- Question -->
        <div id="questionCard">
          <h2 id="questionText" class="font-heading font-bold text-lg md:text-xl text-brand-text leading-relaxed mb-5">
            <!-- filled by JS -->
          </h2>

          <!-- Options -->
          <div id="optionsContainer" class="space-y-2.5">
            <!-- filled by JS -->
          </div>

          <!-- Inline Explanation (hidden until answered) -->
          <div id="explanationBox" class="hidden mt-5 transition-all duration-300">
            <div id="explanationInner" class="rounded-xl p-4 md:p-5">
              <p id="explanationResult" class="font-heading font-bold text-sm mb-1.5"></p>
              <p id="explanationText" class="font-body text-sm text-brand-subtle leading-relaxed"></p>
            </div>
          </div>

          <!-- Next Button -->
          <div id="nextBtnWrapper" class="hidden mt-5">
            <button id="nextBtn" class="w-full py-3.5 gold-gradient text-white font-heading font-semibold rounded-xl text-sm hover:opacity-90 transition-opacity flex items-center justify-center gap-2">
              <span id="nextBtnText">Next Question</span>
              <iconify-icon icon="solar:arrow-right-linear" class="text-lg"></iconify-icon>
            </button>
          </div>
        </div>
      </div>

      <!-- ==================== RESULTS SCREEN ==================== -->
      <div id="resultsScreen" class="hidden">

        <!-- Score Header -->
        <div class="text-center mb-10">
          <div class="relative w-48 h-48 mx-auto mb-6">
            <svg class="w-48 h-48 -rotate-90" viewBox="0 0 192 192">
              <circle cx="96" cy="96" r="84" fill="none" stroke="#e5e7eb" stroke-width="12" />
              <circle id="resultRing" cx="96" cy="96" r="84" fill="none" stroke="#C5A55A" stroke-width="12"
                stroke-linecap="round"
                stroke-dasharray="527.79"
                stroke-dashoffset="527.79"
                style="transition: stroke-dashoffset 1.5s cubic-bezier(0.4, 0, 0.2, 1), stroke 0.5s ease;" />
            </svg>
            <div class="absolute inset-0 flex flex-col items-center justify-center">
              <span id="resultScore" class="font-heading font-bold text-5xl text-brand-text">0</span>
              <span class="font-body text-sm text-brand-subtle">/ 100</span>
            </div>
          </div>

          <!-- Level Badge -->
          <div id="resultLevelBadge" class="inline-flex items-center gap-2 px-5 py-2 rounded-full text-base font-heading font-semibold mb-3">
            <!-- filled by JS -->
          </div>
          <p id="resultLevelDesc" class="font-body text-brand-subtle text-sm md:text-base max-w-lg mx-auto leading-relaxed"></p>
        </div>

        <!-- Category Breakdown -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10">
          <div class="bg-brand-light-surface rounded-xl p-4 border border-brand-light-border text-center" id="catScore0">
            <div class="w-8 h-8 rounded-lg bg-amber-100 flex items-center justify-center mx-auto mb-2">
              <iconify-icon icon="solar:clipboard-list-bold" class="text-brand-accent"></iconify-icon>
            </div>
            <p class="font-body text-xs text-brand-subtle mb-1">PM Fundamentals</p>
            <p class="font-heading font-bold text-lg text-brand-text"><span id="catVal0">0</span><span class="text-sm text-brand-subtle font-normal"> / 20</span></p>
          </div>
          <div class="bg-brand-light-surface rounded-xl p-4 border border-brand-light-border text-center" id="catScore1">
            <div class="w-8 h-8 rounded-lg bg-violet-100 flex items-center justify-center mx-auto mb-2">
              <iconify-icon icon="solar:cpu-bolt-bold" class="text-violet-600"></iconify-icon>
            </div>
            <p class="font-body text-xs text-brand-subtle mb-1">AI Literacy</p>
            <p class="font-heading font-bold text-lg text-brand-text"><span id="catVal1">0</span><span class="text-sm text-brand-subtle font-normal"> / 30</span></p>
          </div>
          <div class="bg-brand-light-surface rounded-xl p-4 border border-brand-light-border text-center" id="catScore2">
            <div class="w-8 h-8 rounded-lg bg-amber-100 flex items-center justify-center mx-auto mb-2">
              <iconify-icon icon="solar:chat-round-dots-bold" class="text-amber-600"></iconify-icon>
            </div>
            <p class="font-body text-xs text-brand-subtle mb-1">Prompt Eng.</p>
            <p class="font-heading font-bold text-lg text-brand-text"><span id="catVal2">0</span><span class="text-sm text-brand-subtle font-normal"> / 30</span></p>
          </div>
          <div class="bg-brand-light-surface rounded-xl p-4 border border-brand-light-border text-center" id="catScore3">
            <div class="w-8 h-8 rounded-lg bg-emerald-100 flex items-center justify-center mx-auto mb-2">
              <iconify-icon icon="solar:database-bold" class="text-emerald-600"></iconify-icon>
            </div>
            <p class="font-body text-xs text-brand-subtle mb-1">Data Thinking</p>
            <p class="font-heading font-bold text-lg text-brand-text"><span id="catVal3">0</span><span class="text-sm text-brand-subtle font-normal"> / 20</span></p>
          </div>
        </div>

        <!-- Per-question Review -->
        <div class="mb-10">
          <button id="toggleReview" class="w-full flex items-center justify-between px-6 py-4 bg-brand-light-surface rounded-2xl border border-brand-light-border hover:border-brand-accent/30 transition-colors">
            <span class="font-heading font-semibold text-brand-text">Question-by-Question Review</span>
            <iconify-icon id="toggleReviewIcon" icon="solar:alt-arrow-down-linear" class="text-xl text-brand-subtle transition-transform duration-300"></iconify-icon>
          </button>
          <div id="reviewContainer" class="hidden mt-4 space-y-3">
            <!-- filled by JS -->
          </div>
        </div>

        <!-- Action Buttons -->
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-12">
          <button id="resultShareBtn" class="inline-flex items-center gap-2 px-8 py-3.5 gold-gradient text-white font-heading font-semibold rounded-full text-sm hover:opacity-90 transition-opacity">
            <iconify-icon icon="solar:share-bold"></iconify-icon>
            Share Results
          </button>
          <button id="retakeBtn" class="inline-flex items-center gap-2 px-8 py-3.5 border border-brand-light-border font-heading font-semibold rounded-full text-sm text-brand-subtle hover:text-brand-accent hover:border-brand-accent transition-colors">
            <iconify-icon icon="solar:refresh-linear"></iconify-icon>
            Retake Assessment
          </button>
        </div>

        <!-- Newsletter CTA -->
        <div class="rounded-2xl bg-gradient-to-br from-amber-50 to-amber-50 p-8 md:p-12 text-center">
          <iconify-icon icon="solar:letter-bold" class="text-brand-accent text-3xl mb-4"></iconify-icon>
          <h3 class="font-heading font-bold text-xl md:text-2xl text-brand-text mb-3">Want to accelerate your AI PM transition?</h3>
          <p class="font-body text-sm md:text-base text-brand-subtle mb-2 max-w-lg mx-auto">Weekly AI product insights — from tools and workflows to mental models — helping you avoid common pitfalls.</p>
          <p class="font-body text-xs text-brand-accent/60 italic mb-6">500+ product professionals subscribed</p>
          <a href="https://www.linkedin.com/newsletters/ai-applied-playbook%EF%BD%9Caipm-%E6%80%9D%E7%B6%AD%E5%AF%A6%E9%A9%97%E5%AE%A4-7402251966258720768" target="_blank" class="mag-btn inline-flex px-8 py-3.5 gold-gradient text-white font-heading font-semibold rounded-full text-sm tracking-wide no-underline">
            <span>Subscribe for Free</span>
          </a>
        </div>

        <!-- Bottom Note -->
        <div class="mt-10 text-center">
          <p class="font-body text-sm text-brand-subtle">This assessment is based on Angela Jian's AI PM competency framework, for reference only. Real competence comes from practice.</p>
        </div>

      </div>

    </div>
  </div>
</main>

<style is:global>
  .quiz-option {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 1rem;
    border-radius: 0.75rem;
    border: 2px solid #e5e7eb;
    background: #fafafa;
    cursor: pointer;
    transition: all 0.2s ease;
    user-select: none;
  }
  .quiz-option:hover:not(.quiz-option-disabled) {
    border-color: #C5A55A;
    background: #f0f0ff;
  }
  .quiz-option-disabled {
    pointer-events: none;
  }
  .quiz-option.selected-correct {
    border-color: #22c55e;
    background: #f0fdf4;
    animation: popCorrect 0.4s ease;
  }
  .quiz-option.selected-wrong {
    border-color: #ef4444;
    background: #fef2f2;
    animation: shakeWrong 0.4s ease;
  }
  .quiz-option.reveal-correct {
    border-color: #22c55e;
    background: #f0fdf4;
  }
  .quiz-option.dimmed {
    opacity: 0.45;
  }

  .option-letter {
    flex-shrink: 0;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.8rem;
    background: #e5e7eb;
    color: #6b7280;
    transition: all 0.2s ease;
  }
  .quiz-option:hover:not(.quiz-option-disabled) .option-letter {
    background: #C5A55A;
    color: white;
  }
  .selected-correct .option-letter {
    background: #22c55e;
    color: white;
  }
  .selected-wrong .option-letter {
    background: #ef4444;
    color: white;
  }
  .reveal-correct .option-letter {
    background: #22c55e;
    color: white;
  }

  .explanation-correct {
    background: #f0fdf4;
    border-left: 3px solid #22c55e;
  }
  .explanation-wrong {
    background: #fef2f2;
    border-left: 3px solid #ef4444;
  }

  @keyframes popCorrect {
    0% { transform: scale(1); }
    50% { transform: scale(1.02); }
    100% { transform: scale(1); }
  }
  @keyframes shakeWrong {
    0%, 100% { transform: translateX(0); }
    20% { transform: translateX(-6px); }
    40% { transform: translateX(6px); }
    60% { transform: translateX(-4px); }
    80% { transform: translateX(4px); }
  }

  .review-item {
    padding: 1rem 1.25rem;
    border-radius: 0.875rem;
    border: 1px solid #e5e7eb;
    background: #f9fafb;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .review-item:hover {
    border-color: rgba(197, 165, 90, 0.3);
  }
  .review-item-detail {
    display: none;
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid #e5e7eb;
  }
  .review-item.open .review-item-detail {
    display: block;
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-in {
    animation: fadeInUp 0.4s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }

  @keyframes countUp {
    from { opacity: 0; }
    to { opacity: 1; }
  }
</style>

<script is:inline>
(function() {
  /* ============================
     QUESTION DATA
     ============================ */
  var QUESTIONS = [
    // Category 0: PM Fundamentals (10 pts each, 2 questions = 20 total)
    {
      category: 0,
      text: 'An A/B test shows the new button increased CTR by 15%, but customer support reports users complaining they "can\'t find the original feature." What do you do?',
      options: [
        'Data speaks — roll out the new version to all users immediately',
        'Ignore the support feedback, the sample size is too small to be representative',
        'Dig deeper: segment data by new vs. existing users, check if it\'s a habit issue, and evaluate long-term retention impact',
        'Roll back to the old version immediately'
      ],
      correct: 2,
      explanation: 'A single metric improvement doesn\'t mean the overall experience improved. CTR increases may come at the cost of other important metrics. PMs need to see the big picture, combining quantitative (data) and qualitative (user feedback) signals.'
    },
    {
      category: 0,
      text: 'Your team receives 5 requests simultaneously: a new feature the CEO wants, a key client\'s customization, tech debt fix, competitor feature catch-up, and the most-reported user bug. How do you prioritize?',
      options: [
        'The CEO\'s request is most important — do it first',
        'Use a RICE/ICE framework to evaluate impact and effort, prioritize data-driven',
        'Fix the bug first — user experience matters most',
        'Chase the competitor feature — can\'t fall behind'
      ],
      correct: 1,
      explanation: 'Good PMs don\'t prioritize by "who shouts loudest" but build a quantifiable prioritization framework. RICE (Reach, Impact, Confidence, Effort) aligns the team and reduces subjective debate.'
    },
    // Category 1: AI Literacy (10 pts each, 3 questions = 30 total)
    {
      category: 1,
      text: 'Your boss wants to add AI auto-reply to the customer service system. What\'s your first step?',
      options: [
        'Integrate the ChatGPT API right away',
        'Audit existing customer service data, assess the scope of problems AI can solve and user expectations',
        'Find an AI engineer and start development immediately',
        'Research every AI customer service product on the market first'
      ],
      correct: 1,
      explanation: 'The success of AI features depends on "problem definition." First understand what problem AI needs to solve, whether existing data can support it, and how much imperfection users will accept — otherwise you\'ll build something nobody uses.'
    },
    {
      category: 1,
      text: 'When designing AI product features, which principle is most important?',
      options: [
        'AI accuracy must reach 99% before launch',
        'Design a Human-in-the-Loop mechanism with fallback plans for when AI makes mistakes',
        'Maximize full automation to minimize human intervention',
        'Use the most advanced model to ensure best results'
      ],
      correct: 1,
      explanation: 'AI output has inherent uncertainty — 100% accuracy is unrealistic. Good AI product design assumes AI will make mistakes and designs graceful fallback mechanisms to ensure errors don\'t cause serious consequences.'
    },
    {
      category: 1,
      text: 'Which scenario is least suitable for an AI solution?',
      options: [
        'Extracting common pain points from a large volume of user reviews',
        'Determining whether the legal clauses in two contracts are exactly equivalent',
        'Recommending relevant content based on user behavior history',
        'Automatically converting meeting recordings into structured meeting notes'
      ],
      correct: 1,
      explanation: 'Precise legal contract comparison requires 100% accuracy, and the cost of errors is severe (legal liability). AI\'s probabilistic output is not suitable for scenarios demanding absolute precision with zero tolerance for error.'
    },
    // Category 2: Prompt Engineering (10 pts each, 3 questions = 30 total)
    {
      category: 2,
      text: 'You want to use an LLM to auto-generate PRD drafts for the PM team. Which prompt design is most effective?',
      options: [
        '"Help me write a PRD"',
        '"You are a senior product manager. Based on the following feature requirement [X], produce a PRD including User Stories, Acceptance Criteria, and Edge Cases, output in Markdown format"',
        '"Write a very detailed PRD, the longer the better"',
        '"Write a PRD in the style of a Google PM"'
      ],
      correct: 1,
      explanation: 'A good prompt = Role + Context (input) + Task + Format (output). Structured instructions make AI output more stable and aligned with expectations.'
    },
    {
      category: 2,
      text: 'You designed a System Prompt for an AI customer service bot, but the AI occasionally answers about features the product doesn\'t support. What\'s the most effective fix?',
      options: [
        'Add "don\'t make things up" to the prompt',
        'Explicitly list the product\'s feature scope in the System Prompt and add an instruction: "For out-of-scope questions, reply: Please contact human support"',
        'Set Temperature to 0',
        'Switch to a larger model'
      ],
      correct: 1,
      explanation: 'Prompt "boundary definition" is critical. Explicitly telling the AI what it can and cannot say, and how to handle out-of-scope questions, is far more effective than vague instructions like "don\'t make things up."'
    },
    {
      category: 2,
      text: 'You\'re using GPT-4 for competitive analysis and notice a pricing detail in the response differs from the official website. Best approach?',
      options: [
        'The AI is probably right — use it as-is',
        'Flag it as "needs verification" and cross-check with real-time search tools',
        'The entire report is unreliable now — redo everything',
        'Ask a different AI model the same question'
      ],
      correct: 1,
      explanation: 'LLMs produce hallucinations, especially with real-time information (pricing, data). The right approach is to keep AI\'s structural output but manually verify factual claims.'
    },
    // Category 3: Data Thinking (10 pts each, 2 questions = 20 total)
    {
      category: 3,
      text: 'You discover that female users make up only 15% of your training data. What problem does this cause?',
      options: [
        'No problem — the AI will balance itself automatically',
        'The model may have lower prediction accuracy for female users, producing bias',
        'As long as the total dataset is large enough, it doesn\'t matter',
        'This is an engineering problem — PMs don\'t need to worry about it'
      ],
      correct: 1,
      explanation: 'Training data distribution directly affects model performance. Imbalanced samples lead to worse predictions for underrepresented groups (bias). PMs are responsible for raising data fairness requirements during the requirements phase.'
    },
    {
      category: 3,
      text: 'Your AI model has 95% Precision and 60% Recall. In which scenario is this trade-off reasonable?',
      options: [
        'Spam filtering — better to miss some spam than to wrongly flag normal emails',
        'Medical diagnostic screening — can\'t miss any potential cases',
        'Any scenario should aim for both high Precision and high Recall',
        'This trade-off indicates the model is flawed and needs retraining'
      ],
      correct: 0,
      explanation: 'High Precision + low Recall means "better to miss than to misclassify." This suits scenarios where false positives are costly (e.g., flagging normal emails as spam is very annoying). Medical screening needs high Recall (can\'t miss diagnoses), and can accept lower Precision.'
    }
  ];

  var CATEGORIES = [
    { name: 'PM Fundamentals', icon: 'solar:clipboard-list-bold', colorBg: 'background:#F3EDE4;', colorText: 'color:#C5A55A;', maxScore: 20, perQ: 10 },
    { name: 'AI Literacy', icon: 'solar:cpu-bolt-bold', colorBg: 'background:#ede9fe;', colorText: 'color:#7c3aed;', maxScore: 30, perQ: 10 },
    { name: 'Prompt Engineering', icon: 'solar:chat-round-dots-bold', colorBg: 'background:#fef3c7;', colorText: 'color:#d97706;', maxScore: 30, perQ: 10 },
    { name: 'Data Thinking', icon: 'solar:database-bold', colorBg: 'background:#d1fae5;', colorText: 'color:#059669;', maxScore: 20, perQ: 10 }
  ];

  var LEVELS = [
    { min: 0, max: 40, emoji: '\u{1F331}', title: 'Getting Started', badgeBg: '#dcfce7', badgeColor: '#15803d', strokeColor: '#22c55e', desc: 'You have a solid foundation in product thinking, and now is the perfect time to dive into AI. Start with Prompt Engineering \u2014 it offers the highest ROI \u2014 and build intuition by reading AI product case studies.' },
    { min: 41, max: 60, emoji: '\u{1F33F}', title: 'Growing', badgeBg: '#d1fae5', badgeColor: '#047857', strokeColor: '#10b981', desc: 'You have a solid AI PM knowledge base! The next step is gaining more hands-on experience. Find a real project to practice on and turn theory into verifiable product decisions.' },
    { min: 61, max: 80, emoji: '\u{1F333}', title: 'Advanced', badgeBg: '#F3EDE4', badgeColor: '#8B7330', strokeColor: '#C5A55A', desc: 'You demonstrate strong AI PM skills across multiple dimensions. Consider going deeper into AI Evaluation, Data Pipelines, and MLOps to bridge closer with technical teams.' },
    { min: 81, max: 100, emoji: '\u{1F680}', title: 'Expert', badgeBg: '#ede9fe', badgeColor: '#6d28d9', strokeColor: '#8b5cf6', desc: 'You are a rare AI PM talent! Start sharing your experience, building personal brand influence, and staying on top of cutting-edge AI product design patterns and Agent architectures.' }
  ];

  var LETTERS = ['A', 'B', 'C', 'D'];
  var CIRCUMFERENCE = 2 * Math.PI * 84; // ~527.79

  /* ============================
     STATE
     ============================ */
  var currentQ = 0;
  var answers = []; // { selected: idx, correct: bool }
  var categoryScores = [0, 0, 0, 0];
  var answered = false;

  /* ============================
     DOM REFS
     ============================ */
  var startScreen = document.getElementById('startScreen');
  var questionScreen = document.getElementById('questionScreen');
  var resultsScreen = document.getElementById('resultsScreen');
  var startBtn = document.getElementById('startBtn');
  var nextBtn = document.getElementById('nextBtn');
  var nextBtnWrapper = document.getElementById('nextBtnWrapper');
  var nextBtnText = document.getElementById('nextBtnText');
  var progressLabel = document.getElementById('progressLabel');
  var progressBar = document.getElementById('progressBar');
  var categoryBadge = document.getElementById('categoryBadge');
  var questionText = document.getElementById('questionText');
  var optionsContainer = document.getElementById('optionsContainer');
  var explanationBox = document.getElementById('explanationBox');
  var explanationInner = document.getElementById('explanationInner');
  var explanationResult = document.getElementById('explanationResult');
  var explanationText = document.getElementById('explanationText');

  /* ============================
     FUNCTIONS
     ============================ */

  function showScreen(screen) {
    startScreen.classList.add('hidden');
    questionScreen.classList.add('hidden');
    resultsScreen.classList.add('hidden');
    screen.classList.remove('hidden');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function renderQuestion() {
    var q = QUESTIONS[currentQ];
    var cat = CATEGORIES[q.category];
    answered = false;

    // Progress
    var pct = Math.round(((currentQ + 1) / QUESTIONS.length) * 100);
    progressLabel.textContent = 'Question ' + (currentQ + 1) + ' / ' + QUESTIONS.length;
    progressBar.style.width = pct + '%';

    // Category badge
    categoryBadge.setAttribute('style', cat.colorBg + cat.colorText);
    categoryBadge.innerHTML = '<iconify-icon icon="' + cat.icon + '" style="font-size:0.85rem;"></iconify-icon> ' + cat.name;

    // Question text
    questionText.textContent = q.text;

    // Options
    optionsContainer.innerHTML = '';
    for (var i = 0; i < q.options.length; i++) {
      var optDiv = document.createElement('div');
      optDiv.className = 'quiz-option';
      optDiv.setAttribute('data-idx', i);
      optDiv.innerHTML = '<div class="option-letter">' + LETTERS[i] + '</div><span class="font-body text-sm text-brand-text leading-relaxed">' + q.options[i] + '</span>';
      optDiv.addEventListener('click', handleOptionClick);
      optionsContainer.appendChild(optDiv);
    }

    // Hide explanation and next button
    explanationBox.classList.add('hidden');
    nextBtnWrapper.classList.add('hidden');

    // Update next button text
    if (currentQ === QUESTIONS.length - 1) {
      nextBtnText.textContent = 'View Results';
    } else {
      nextBtnText.textContent = 'Next Question';
    }

    // Animate in
    var card = document.getElementById('questionCard');
    card.style.opacity = '0';
    card.style.transform = 'translateY(12px)';
    requestAnimationFrame(function() {
      card.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
      card.style.opacity = '1';
      card.style.transform = 'translateY(0)';
    });
  }

  function handleOptionClick(e) {
    if (answered) return;
    answered = true;

    var target = e.currentTarget;
    var selectedIdx = parseInt(target.getAttribute('data-idx'), 10);
    var q = QUESTIONS[currentQ];
    var isCorrect = selectedIdx === q.correct;

    // Record answer
    answers.push({ selected: selectedIdx, correct: isCorrect });
    if (isCorrect) {
      categoryScores[q.category] += CATEGORIES[q.category].perQ;
    }

    // Disable all options and dim non-selected wrong ones
    var allOpts = optionsContainer.querySelectorAll('.quiz-option');
    for (var i = 0; i < allOpts.length; i++) {
      allOpts[i].classList.add('quiz-option-disabled');
      if (i === q.correct) {
        allOpts[i].classList.add('reveal-correct');
      } else if (parseInt(allOpts[i].getAttribute('data-idx'), 10) !== selectedIdx) {
        allOpts[i].classList.add('dimmed');
      }
    }

    // Mark selected
    if (isCorrect) {
      target.classList.remove('reveal-correct');
      target.classList.add('selected-correct');
    } else {
      target.classList.add('selected-wrong');
    }

    // Show explanation inline
    explanationBox.classList.remove('hidden');
    explanationInner.className = 'rounded-xl p-4 md:p-5 ' + (isCorrect ? 'explanation-correct' : 'explanation-wrong');
    if (isCorrect) {
      explanationResult.innerHTML = '<iconify-icon icon="solar:check-circle-bold" style="color:#22c55e;vertical-align:-2px;margin-right:4px;"></iconify-icon> Correct!';
      explanationResult.style.color = '#16a34a';
    } else {
      explanationResult.innerHTML = '<iconify-icon icon="solar:close-circle-bold" style="color:#ef4444;vertical-align:-2px;margin-right:4px;"></iconify-icon> Incorrect! The correct answer is ' + LETTERS[q.correct];
      explanationResult.style.color = '#dc2626';
    }
    explanationText.textContent = q.explanation;

    // Show next button immediately below
    nextBtnWrapper.classList.remove('hidden');
  }

  function showResults() {
    showScreen(resultsScreen);

    var totalScore = 0;
    for (var i = 0; i < categoryScores.length; i++) {
      totalScore += categoryScores[i];
    }
    totalScore = Math.round(totalScore);

    // Animate score number
    var scoreEl = document.getElementById('resultScore');
    var ring = document.getElementById('resultRing');
    var startVal = 0;
    var duration = 1200;
    var startTime = null;

    function animateScore(timestamp) {
      if (!startTime) startTime = timestamp;
      var progress = Math.min((timestamp - startTime) / duration, 1);
      var eased = 1 - Math.pow(1 - progress, 3);
      var currentVal = Math.round(eased * totalScore);
      scoreEl.textContent = currentVal;

      // Update ring
      var offset = CIRCUMFERENCE - (eased * totalScore / 100) * CIRCUMFERENCE;
      ring.setAttribute('stroke-dashoffset', offset);

      if (progress < 1) {
        requestAnimationFrame(animateScore);
      }
    }

    // Get level
    var level = LEVELS[0];
    for (var j = 0; j < LEVELS.length; j++) {
      if (totalScore >= LEVELS[j].min && totalScore <= LEVELS[j].max) {
        level = LEVELS[j];
        break;
      }
    }

    ring.setAttribute('stroke', level.strokeColor);

    setTimeout(function() {
      requestAnimationFrame(animateScore);
    }, 300);

    // Level badge
    var badge = document.getElementById('resultLevelBadge');
    badge.setAttribute('style', 'background:' + level.badgeBg + ';color:' + level.badgeColor + ';');
    badge.textContent = level.emoji + ' ' + level.title;

    document.getElementById('resultLevelDesc').textContent = level.desc;

    // Category scores
    for (var k = 0; k < 4; k++) {
      document.getElementById('catVal' + k).textContent = Math.round(categoryScores[k]);
    }

    // Per-question review
    var reviewContainer = document.getElementById('reviewContainer');
    reviewContainer.innerHTML = '';
    for (var m = 0; m < QUESTIONS.length; m++) {
      var q = QUESTIONS[m];
      var a = answers[m];
      var cat = CATEGORIES[q.category];
      var statusIcon = a.correct
        ? '<iconify-icon icon="solar:check-circle-bold" style="color:#22c55e;font-size:1.25rem;"></iconify-icon>'
        : '<iconify-icon icon="solar:close-circle-bold" style="color:#ef4444;font-size:1.25rem;"></iconify-icon>';

      var div = document.createElement('div');
      div.className = 'review-item';
      div.innerHTML =
        '<div style="display:flex;align-items:center;gap:0.75rem;">' +
          statusIcon +
          '<span style="flex:1;" class="font-body text-sm text-brand-text">' + (m + 1) + '. ' + q.text.substring(0, 60) + (q.text.length > 60 ? '...' : '') + '</span>' +
          '<iconify-icon icon="solar:alt-arrow-down-linear" class="text-brand-subtle" style="font-size:1rem;flex-shrink:0;transition:transform 0.2s;"></iconify-icon>' +
        '</div>' +
        '<div class="review-item-detail">' +
          '<p class="font-body text-sm text-brand-text mb-2" style="font-weight:600;">' + q.text + '</p>' +
          '<p class="font-body text-xs text-brand-subtle mb-1">Your answer: <span style="color:' + (a.correct ? '#16a34a' : '#dc2626') + ';font-weight:600;">' + LETTERS[a.selected] + '. ' + q.options[a.selected] + '</span></p>' +
          (!a.correct ? '<p class="font-body text-xs text-brand-subtle mb-1">Correct answer: <span style="color:#16a34a;font-weight:600;">' + LETTERS[q.correct] + '. ' + q.options[q.correct] + '</span></p>' : '') +
          '<p class="font-body text-xs text-brand-subtle mt-2" style="padding:0.5rem 0.75rem;background:#f9fafb;border-radius:0.5rem;border:1px solid #e5e7eb;">' + q.explanation + '</p>' +
        '</div>';

      div.addEventListener('click', function() {
        var isOpen = this.classList.contains('open');
        this.classList.toggle('open');
        var arrow = this.querySelector('iconify-icon[icon="solar:alt-arrow-down-linear"]');
        if (arrow) {
          arrow.style.transform = isOpen ? 'rotate(0deg)' : 'rotate(180deg)';
        }
      });

      reviewContainer.appendChild(div);
    }
  }

  /* ============================
     EVENT LISTENERS
     ============================ */

  startBtn.addEventListener('click', function() {
    showScreen(questionScreen);
    renderQuestion();
  });

  nextBtn.addEventListener('click', function() {
    if (currentQ < QUESTIONS.length - 1) {
      currentQ++;
      renderQuestion();
      document.getElementById('questionScreen').scrollIntoView({ behavior: 'smooth', block: 'start' });
    } else {
      showResults();
    }
  });

  // Toggle review
  document.getElementById('toggleReview').addEventListener('click', function() {
    var container = document.getElementById('reviewContainer');
    var icon = document.getElementById('toggleReviewIcon');
    var isHidden = container.classList.contains('hidden');
    if (isHidden) {
      container.classList.remove('hidden');
      icon.style.transform = 'rotate(180deg)';
    } else {
      container.classList.add('hidden');
      icon.style.transform = 'rotate(0deg)';
    }
  });

  // Share
  document.getElementById('resultShareBtn').addEventListener('click', function() {
    var totalScore = 0;
    for (var i = 0; i < categoryScores.length; i++) {
      totalScore += categoryScores[i];
    }
    totalScore = Math.round(totalScore);
    var level = LEVELS[0];
    for (var j = 0; j < LEVELS.length; j++) {
      if (totalScore >= LEVELS[j].min && totalScore <= LEVELS[j].max) {
        level = LEVELS[j];
        break;
      }
    }

    var text = 'I scored ' + totalScore + '/100 on the AI PM Skills Assessment ' + level.emoji + ' ' + level.title + '! Try it yourself \u{1F449}';
    var url = window.location.href;

    if (navigator.share) {
      navigator.share({ title: 'AI PM Skills Assessment', text: text, url: url }).catch(function(){});
    } else {
      navigator.clipboard.writeText(text + ' ' + url).then(function() {
        var btn = document.getElementById('resultShareBtn');
        var orig = btn.innerHTML;
        btn.innerHTML = '<iconify-icon icon="solar:check-circle-bold"></iconify-icon> Share text copied!';
        setTimeout(function() { btn.innerHTML = orig; }, 2000);
      });
    }
  });

  // Retake
  document.getElementById('retakeBtn').addEventListener('click', function() {
    currentQ = 0;
    answers = [];
    categoryScores = [0, 0, 0, 0];
    answered = false;
    showScreen(startScreen);
  });

})();
</script>

</Base>
