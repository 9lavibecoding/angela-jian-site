---
import Base from '../../layouts/Base.astro';
---

<Base title="iPAS AI 題庫 — 1000 題完整練習 | AI PM INSIDER" description="1000 道 iPAS 初級人工智慧應用師考題，互動答題、章節練習、答對率統計、3 套模擬考卷（計時 60 分鐘），前 100 名特價 NT$699">

<!-- JSON-LD: Product -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "iPAS AI 題庫 — 1000 題完整版",
  "description": "涵蓋 L11 基礎 AI 概念、L12 生成式 AI 應用、綜合模擬考，每題附詳細解析。互動答題、章節練習、答對率統計、3 套模擬考卷（計時 60 分鐘）、PDF 離線下載。",
  "brand": { "@type": "Person", "name": "Angela Jian 簡琬庭" },
  "offers": {
    "@type": "Offer",
    "price": "699",
    "priceCurrency": "TWD",
    "availability": "https://schema.org/InStock",
    "url": Astro.site ? new URL("/exam/", Astro.site).toString() : "/exam/"
  },
  "category": "Digital Product",
  "audience": { "@type": "Audience", "audienceType": "iPAS AI 應用規劃師考生" }
})} />

<!-- JSON-LD: FAQ -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "iPAS AI 題庫包含哪些內容？",
      "acceptedAnswer": { "@type": "Answer", "text": "共 1000 道考題，分為 L11 基礎 AI 概念（300 題）、L12 生成式 AI 應用（300 題）、綜合模擬（400 題），每題附詳細白話解析。包含互動答題、章節練習、答對率統計、3 套模擬考卷（計時 60 分鐘）及 PDF 離線下載。" }
    },
    {
      "@type": "Question",
      "name": "購買後可以使用多久？",
      "acceptedAnswer": { "@type": "Answer", "text": "PDF 題庫下載後永久保存。線上互動平台（章節練習、模擬考、統計）提供自購買日起 6 個月使用權，涵蓋一整個考季。" }
    },
    {
      "@type": "Question",
      "name": "跟政府公布的考古題有什麼不同？",
      "acceptedAnswer": { "@type": "Answer", "text": "政府公布的考古題數量有限且沒有解析，很難靠死背通過考試。本題庫由高分通過的作者設計，1000 題涵蓋所有考試範圍，每題都附白話解析幫你融會貫通，而不只是背答案。" }
    },
    {
      "@type": "Question",
      "name": "題庫支援哪些付款方式？",
      "acceptedAnswer": { "@type": "Answer", "text": "透過綠界 ECPay 安全付款，支援信用卡（Visa / Mastercard / JCB）、ATM 轉帳、超商代碼繳費。" }
    }
  ]
})} />

<!-- JSON-LD: BreadcrumbList -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "首頁", "item": Astro.site?.toString() },
    { "@type": "ListItem", "position": 2, "name": "iPAS AI 課程", "item": Astro.site ? new URL("/ipas", Astro.site).toString() : "/ipas" },
    { "@type": "ListItem", "position": 3, "name": "iPAS AI 題庫", "item": Astro.site ? new URL("/exam/", Astro.site).toString() : "/exam/" }
  ]
})} />

<main class="pt-28 pb-20 min-h-screen bg-white">
  <div class="site-container px-6">

    <!-- Back -->
    <div class="mb-8">
      <a href="/ipas" class="inline-flex items-center gap-2 text-sm font-body text-brand-subtle hover:text-brand-accent transition-colors mb-6">
        <iconify-icon icon="solar:arrow-left-linear"></iconify-icon>
        返回 iPAS 課程
      </a>
    </div>

    <div class="max-w-4xl mx-auto">

      <!-- Hero -->
      <div class="text-center mb-16">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-red-50 text-red-600 text-sm font-body font-semibold mb-6">
          <iconify-icon icon="solar:fire-bold"></iconify-icon>
          前 100 名早鳥特價
        </div>
        <h1 class="font-heading font-bold text-3xl md:text-4xl lg:text-5xl text-brand-text mb-5 leading-tight">
          iPAS AI 證照題庫<br class="hidden md:block">
          <span class="gold-text">1000 題完整版</span>
        </h1>
        <p class="font-body text-brand-subtle text-base md:text-lg max-w-2xl mx-auto mb-10 leading-relaxed">
          AI 不是背多分，是融會貫通。<br class="hidden md:block">
          由高分通過 iPAS 的作者親自設計，用最生活化的例子幫你真正理解每個概念。
        </p>

        <!-- Price -->
        <div class="inline-flex flex-col items-center bg-white rounded-2xl border-2 border-brand-accent/30 p-6 md:p-8 mb-8 shadow-lg">
          <div class="flex items-center gap-2 mb-2">
            <span class="font-body text-sm text-brand-subtle line-through">NT$1,199</span>
            <span class="px-2 py-0.5 rounded-full bg-red-100 text-red-600 text-[10px] font-heading font-bold">-42%</span>
          </div>
          <span class="font-heading font-black text-3xl md:text-5xl text-brand-text mb-3">NT$699</span>
          <div class="flex items-center gap-3 text-[11px] font-body text-brand-subtle mb-5">
            <span class="flex items-center gap-1"><iconify-icon icon="solar:document-text-bold" class="text-sm text-brand-accent"></iconify-icon>PDF 永久保存</span>
            <span class="text-brand-light-border">|</span>
            <span class="flex items-center gap-1"><iconify-icon icon="solar:monitor-bold" class="text-sm text-brand-accent"></iconify-icon>線上平台 6 個月</span>
          </div>
          <button id="buyBtn" class="mag-btn w-full px-8 py-3 gold-gradient text-white font-heading font-semibold rounded-full text-sm tracking-wide hover:opacity-90 transition-opacity mb-3">
            <span>立即購買題庫</span>
          </button>
          <div class="flex items-center gap-2 text-[10px] font-body text-brand-subtle/60">
            <iconify-icon icon="solar:lock-bold" class="text-xs"></iconify-icon>
            <span>綠界安全付款 · 信用卡 / ATM / 超商</span>
          </div>
          <div class="flex items-center gap-3 mt-3">
            <a href="/exam/app" class="font-body text-[11px] text-brand-subtle hover:text-brand-accent transition-colors underline">已購買？登入</a>
            <a href="/terms" class="font-body text-[11px] text-brand-subtle hover:text-brand-accent transition-colors underline">使用條款</a>
          </div>
        </div>
      </div>

      <!-- 為什麼需要這個題庫 -->
      <div class="mb-16">
        <h2 class="font-heading font-bold text-2xl text-brand-text text-center mb-8">為什麼只看考古題不夠？</h2>
        <div class="grid md:grid-cols-2 gap-6">
          <div class="rounded-2xl border border-gray-100 p-6">
            <div class="flex items-center gap-2 mb-3">
              <div class="w-8 h-8 rounded-lg bg-red-100 flex items-center justify-center">
                <iconify-icon icon="solar:close-circle-bold" class="text-lg text-red-500"></iconify-icon>
              </div>
              <span class="font-heading font-bold text-sm text-red-500">只看政府考古題</span>
            </div>
            <ul class="space-y-2 font-body text-sm text-brand-subtle">
              <li class="flex items-start gap-2"><span class="text-red-400 mt-0.5">&#x2717;</span>題數太少，涵蓋範圍不夠</li>
              <li class="flex items-start gap-2"><span class="text-red-400 mt-0.5">&#x2717;</span>沒有解析，錯了也不知道為什麼</li>
              <li class="flex items-start gap-2"><span class="text-red-400 mt-0.5">&#x2717;</span>容易落入「背答案」的陷阱</li>
              <li class="flex items-start gap-2"><span class="text-red-400 mt-0.5">&#x2717;</span>考題換個說法就不會了</li>
            </ul>
          </div>
          <div class="rounded-2xl border border-emerald-200 bg-emerald-50/30 p-6">
            <div class="flex items-center gap-2 mb-3">
              <div class="w-8 h-8 rounded-lg bg-emerald-100 flex items-center justify-center">
                <iconify-icon icon="solar:check-circle-bold" class="text-lg text-emerald-600"></iconify-icon>
              </div>
              <span class="font-heading font-bold text-sm text-emerald-600">本題庫的做法</span>
            </div>
            <ul class="space-y-2 font-body text-sm text-brand-subtle">
              <li class="flex items-start gap-2"><span class="text-emerald-500 mt-0.5">&#x2713;</span>1000 題完整涵蓋所有考試範圍</li>
              <li class="flex items-start gap-2"><span class="text-emerald-500 mt-0.5">&#x2713;</span>每題附白話解析，用生活例子幫你理解</li>
              <li class="flex items-start gap-2"><span class="text-emerald-500 mt-0.5">&#x2713;</span>融會貫通，不是死背答案</li>
              <li class="flex items-start gap-2"><span class="text-emerald-500 mt-0.5">&#x2713;</span>3 套模擬考，提前適應考試節奏</li>
            </ul>
          </div>
        </div>
      </div>

      <!-- 作者背書 -->
      <div class="mb-16 rounded-2xl bg-[#F9FAFB] border border-gray-100 p-8 md:p-10">
        <div class="flex flex-col md:flex-row items-center gap-6">
          <div class="w-20 h-20 rounded-full overflow-hidden shrink-0">
            <img src="/avatar-vector.webp" alt="Angela Jian" class="w-full h-full object-cover">
          </div>
          <div>
            <p class="font-body text-base text-brand-text leading-relaxed">
              「我自己考 iPAS 的經驗是：<strong>官方考古題完全不夠用</strong>。AI 的考題不像法規可以背，它考的是你對概念的理解程度。上半場的「人工智慧基礎概論」還能靠多看多學來拿分，但下半場的「生成式 AI 應用與規劃」才是真正的大魔王，題目又長、情境又複雜，需要有邏輯地思考才有機會拿高分。所以我把每一題都設計成情境題，用生活化的例子讓你真正搞懂，而不是死記硬背。」
            </p>
          </div>
        </div>
      </div>

      <!-- 你會得到什麼 -->
      <div class="mb-16">
        <h2 class="font-heading font-bold text-2xl text-brand-text text-center mb-8">你會得到什麼？</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <div class="text-center py-6 px-4 rounded-2xl bg-[#F9FAFB]">
            <p class="font-heading font-black text-3xl md:text-4xl text-brand-accent mb-1">1000</p>
            <p class="font-heading font-bold text-sm text-brand-text">道情境題</p>
            <p class="font-body text-[11px] text-brand-subtle mt-1">基礎概論 · 生成式 AI · 綜合</p>
          </div>
          <div class="text-center py-6 px-4 rounded-2xl bg-[#F9FAFB]">
            <p class="font-heading font-black text-3xl md:text-4xl text-emerald-600 mb-1">3 套</p>
            <p class="font-heading font-bold text-sm text-brand-text">模擬考卷</p>
            <p class="font-body text-[11px] text-brand-subtle mt-1">50 題 · 60 分鐘計時</p>
          </div>
          <div class="text-center py-6 px-4 rounded-2xl bg-[#F9FAFB]">
            <p class="font-heading font-black text-3xl md:text-4xl text-violet-600 mb-1">每題</p>
            <p class="font-heading font-bold text-sm text-brand-text">白話解析</p>
            <p class="font-body text-[11px] text-brand-subtle mt-1">不只背答案，搞懂原理</p>
          </div>
          <div class="text-center py-6 px-4 rounded-2xl bg-[#F9FAFB]">
            <p class="font-heading font-black text-3xl md:text-4xl text-brand-text mb-1">PDF</p>
            <p class="font-heading font-bold text-sm text-brand-text">離線下載</p>
            <p class="font-body text-[11px] text-brand-subtle mt-1">通勤隨時翻閱複習</p>
          </div>
        </div>
      </div>

      <!-- FAQ -->
      <div class="mb-16">
        <h2 class="font-heading font-bold text-2xl text-brand-text text-center mb-8">常見問題</h2>
        <div class="space-y-3 max-w-2xl mx-auto">
          <div class="faq-item bg-white rounded-xl border border-brand-light-border overflow-hidden">
            <button class="faq-toggle w-full flex items-center justify-between px-6 py-4 text-left">
              <span class="font-heading font-semibold text-sm text-brand-text">購買後可以使用多久？</span>
              <iconify-icon icon="solar:alt-arrow-down-linear" class="text-brand-subtle text-lg faq-arrow transition-transform duration-300"></iconify-icon>
            </button>
            <div class="faq-content hidden px-6 pb-4">
              <p class="font-body text-sm text-brand-subtle">PDF 題庫下載後永久保存，隨時離線複習。線上互動平台（章節練習、模擬考、統計）提供自購買日起 6 個月使用權，涵蓋一整個考季，從零基礎到上考場綽綽有餘。</p>
            </div>
          </div>
          <div class="faq-item bg-white rounded-xl border border-brand-light-border overflow-hidden">
            <button class="faq-toggle w-full flex items-center justify-between px-6 py-4 text-left">
              <span class="font-heading font-semibold text-sm text-brand-text">跟政府公布的考古題有什麼不同？</span>
              <iconify-icon icon="solar:alt-arrow-down-linear" class="text-brand-subtle text-lg faq-arrow transition-transform duration-300"></iconify-icon>
            </button>
            <div class="faq-content hidden px-6 pb-4">
              <p class="font-body text-sm text-brand-subtle">政府公布的考古題數量有限且沒有解析。本題庫 1000 題全部附白話解析，用情境式出題幫你融會貫通，而不是死背答案。</p>
            </div>
          </div>
          <div class="faq-item bg-white rounded-xl border border-brand-light-border overflow-hidden">
            <button class="faq-toggle w-full flex items-center justify-between px-6 py-4 text-left">
              <span class="font-heading font-semibold text-sm text-brand-text">付款方式是什麼？</span>
              <iconify-icon icon="solar:alt-arrow-down-linear" class="text-brand-subtle text-lg faq-arrow transition-transform duration-300"></iconify-icon>
            </button>
            <div class="faq-content hidden px-6 pb-4">
              <p class="font-body text-sm text-brand-subtle">透過綠界 ECPay 安全付款，支援信用卡（Visa / Mastercard / JCB）、ATM 轉帳、超商代碼繳費。</p>
            </div>
          </div>
          <div class="faq-item bg-white rounded-xl border border-brand-light-border overflow-hidden">
            <button class="faq-toggle w-full flex items-center justify-between px-6 py-4 text-left">
              <span class="font-heading font-semibold text-sm text-brand-text">可以在手機上使用嗎？</span>
              <iconify-icon icon="solar:alt-arrow-down-linear" class="text-brand-subtle text-lg faq-arrow transition-transform duration-300"></iconify-icon>
            </button>
            <div class="faq-content hidden px-6 pb-4">
              <p class="font-body text-sm text-brand-subtle">完全支援！題庫介面為響應式設計，手機、平板、電腦都能流暢使用，也可下載 PDF 離線閱讀。</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Bottom CTA -->
      <div class="text-center rounded-2xl bg-gradient-to-br from-amber-50 to-amber-50/50 p-10 md:p-14 border border-brand-light-border">
        <iconify-icon icon="solar:medal-ribbons-star-bold" class="text-brand-accent text-4xl mb-4"></iconify-icon>
        <h2 class="font-heading font-bold text-2xl md:text-3xl text-brand-text mb-3">準備好拿下 iPAS AI 證照了嗎？</h2>
        <p class="font-body text-brand-subtle mb-2 max-w-lg mx-auto">1000 題 PDF 永久保存 + 6 個月線上模擬考，用最有效率的方式通過考試。</p>
        <p class="font-body text-sm text-red-500 font-semibold mb-6">前 100 名早鳥價 NT$699（原價 NT$1,199）</p>
        <button id="buyBtn2" class="mag-btn px-12 py-4 gold-gradient text-white font-heading font-semibold rounded-full text-base tracking-wide hover:opacity-90 transition-opacity">
          <span>NT$699 — 立即購買</span>
        </button>
      </div>

    </div>
  </div>
</main>

<script is:inline>
(function() {
  // 檢查是否已購買
  var purchased = localStorage.getItem('ipas_exam_purchased');
  if (purchased) {
    var btns = document.querySelectorAll('#buyBtn, #buyBtn2');
    btns.forEach(function(btn) {
      btn.innerHTML = '<span>進入題庫</span>';
      btn.addEventListener('click', function() {
        window.location.href = '/exam/app';
      });
    });
    return;
  }

  // 購買按鈕
  function handleBuy() {
    var btn = this;
    btn.disabled = true;
    btn.innerHTML = '<span>導向付款頁面...</span>';

    fetch('/api/create-order', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
    })
    .then(function(res) { return res.json(); })
    .then(function(data) {
      if (data.params && data.actionUrl) {
        var form = document.createElement('form');
        form.method = 'POST';
        form.action = data.actionUrl;
        form.style.display = 'none';
        Object.keys(data.params).forEach(function(key) {
          var input = document.createElement('input');
          input.type = 'hidden';
          input.name = key;
          input.value = data.params[key];
          form.appendChild(input);
        });
        document.body.appendChild(form);
        form.submit();
      } else {
        alert(data.error || '發生錯誤，請稍後再試');
        btn.disabled = false;
        btn.innerHTML = '<span>立即購買題庫</span>';
      }
    })
    .catch(function() {
      alert('網路錯誤，請稍後再試');
      btn.disabled = false;
      btn.innerHTML = '<span>立即購買題庫</span>';
    });
  }

  document.getElementById('buyBtn').addEventListener('click', handleBuy);
  document.getElementById('buyBtn2').addEventListener('click', handleBuy);

  // FAQ 摺疊
  document.querySelectorAll('.faq-toggle').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var content = this.nextElementSibling;
      var arrow = this.querySelector('.faq-arrow');
      var isHidden = content.classList.contains('hidden');
      content.classList.toggle('hidden');
      arrow.style.transform = isHidden ? 'rotate(180deg)' : 'rotate(0deg)';
    });
  });
})();
</script>

</Base>
