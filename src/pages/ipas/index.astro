---
import Base from '../../layouts/Base.astro';
import { getIPASLessons } from '../../lib/notion';

const lessons = await getIPASLessons();

// Group by stage
const stages = new Map<string, typeof lessons>();
for (const lesson of lessons) {
  const key = lesson.stage;
  if (!stages.has(key)) stages.set(key, []);
  stages.get(key)!.push(lesson);
}
const sortedStages = [...stages.entries()].sort(
  (a, b) => a[1][0].stageOrder - b[1][0].stageOrder
);

const totalLessons = lessons.length;
---

<Base title="iPAS AI 應用規劃師｜51 篇免費證照備考教學 — Angela Jian" description="51 篇白話教學文章，用生活化比喻與圖解，帶你從零基礎考取經濟部 iPAS AI 應用規劃師初級證照。涵蓋 AI 基礎、機器學習、生成式 AI、法規治理與模擬考題。">

  <!-- JSON-LD: Course structured data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Course",
    "name": "iPAS AI 應用規劃師初級證照備考教學",
    "description": "51 篇白話教學文章，用生活化比喻與圖解，帶你從零基礎考取經濟部 iPAS AI 應用規劃師初級證照",
    "provider": { "@type": "Person", "name": "Angela Jian 簡琬庭", "url": Astro.site?.toString() },
    "educationalLevel": "Beginner",
    "numberOfLessons": totalLessons,
    "inLanguage": "zh-TW",
    "isAccessibleForFree": true,
    "hasCourseInstance": {
      "@type": "CourseInstance",
      "courseMode": "online",
      "courseWorkload": "PT30H"
    },
    "about": [
      { "@type": "Thing", "name": "人工智慧" },
      { "@type": "Thing", "name": "機器學習" },
      { "@type": "Thing", "name": "生成式 AI" },
      { "@type": "Thing", "name": "AI 治理" }
    ],
    "teaches": ["AI 基礎概念", "資料處理與分析", "機器學習模型", "生成式 AI 應用", "AI 法規治理", "AI 導入規劃"]
  })} />

  <!-- JSON-LD: FAQ for Answer Engine Optimization -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "iPAS AI 應用規劃師是什麼？",
        "acceptedAnswer": { "@type": "Answer", "text": "iPAS AI 應用規劃師是經濟部工業局推動的「經濟部產業人才能力鑑定」（iPAS）證照之一，分為初級與中級。初級考試涵蓋 AI 基礎概論與生成式 AI 應用規劃兩大科目，適合想進入 AI 領域的非技術背景人士。" }
      },
      {
        "@type": "Question",
        "name": "iPAS AI 應用規劃師考什麼？",
        "acceptedAnswer": { "@type": "Answer", "text": "初級考試分兩科：（1）人工智慧基礎概論，涵蓋 AI 定義與分類、AI 治理、資料處理與分析、機器學習、鑑別式與生成式 AI；（2）生成式 AI 應用與規劃，涵蓋 No Code/Low Code、生成式 AI 工具應用、導入評估規劃與風險管理。" }
      },
      {
        "@type": "Question",
        "name": "iPAS AI 應用規劃師好考嗎？需要技術背景嗎？",
        "acceptedAnswer": { "@type": "Answer", "text": "初級不需要程式背景，考的是 AI 概念理解與應用規劃能力。本課程用生活化比喻與圖解，讓完全零基礎的人也能理解複雜的技術概念。認真學完 51 篇教學並做完模擬考題，通過率很高。" }
      },
      {
        "@type": "Question",
        "name": "這個課程是免費的嗎？",
        "acceptedAnswer": { "@type": "Answer", "text": "是的，51 篇教學文章全部免費閱讀，包含 3 套模擬考題（共 80 題）和考前速查表。" }
      },
      {
        "@type": "Question",
        "name": "生成式 AI 和鑑別式 AI 有什麼差別？",
        "acceptedAnswer": { "@type": "Answer", "text": "鑑別式 AI 的任務是分類與預測，學習的是 P(Y|X) 條件機率，例如判斷圖片是貓還是狗；生成式 AI 的任務是創造新內容，學習的是資料分布 P(X)，例如 ChatGPT 生成文章、DALL-E 生成圖片。兩者可整合應用，如 GAN 中生成器負責生成、鑑別器負責判斷。" }
      },
      {
        "@type": "Question",
        "name": "什麼是 RAG（檢索增強生成）？",
        "acceptedAnswer": { "@type": "Answer", "text": "RAG（Retrieval-Augmented Generation）是一種解決 AI 幻覺問題的技術。它先從知識庫中檢索相關文件，再將檢索結果注入 LLM 的 prompt 中生成回答，就像開卷考試而非閉卷考試，大幅降低 AI 胡說八道的機率。" }
      }
    ]
  })} />

  <!-- JSON-LD: BreadcrumbList -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "首頁", "item": Astro.site?.toString() },
      { "@type": "ListItem", "position": 2, "name": "iPAS AI 課程", "item": new URL("/ipas", Astro.site).toString() }
    ]
  })} />

  <section class="relative pt-28 md:pt-32 pb-12 md:pb-16 overflow-hidden bg-white">
    <div class="site-container px-6 relative z-10">

      <!-- Back link -->
      <a href="/" class="inline-flex items-center gap-2 text-brand-light-subtle text-sm font-body mb-8 md:mb-10 hover:text-brand-accent-dark transition-colors">
        <iconify-icon icon="solar:arrow-left-linear" class="text-lg"></iconify-icon>
        <span>返回首頁</span>
      </a>

      <!-- Header -->
      <div class="mb-10 md:mb-14">
        <div class="flex items-center gap-3 text-brand-light-subtle text-xs tracking-widest font-body uppercase mb-4 md:mb-6">
          <div class="w-8 h-px bg-brand-accent-dark"></div>
          <span>iPAS Certificate Course</span>
        </div>
        <h1 class="font-heading font-bold text-3xl md:text-5xl lg:text-6xl text-brand-light-text mb-4 md:mb-6">
          iPAS <span class="text-brand-accent-dark">AI 應用規劃師</span>
        </h1>
        <p class="text-base md:text-lg text-brand-light-subtle font-body leading-relaxed max-w-2xl">
          51 篇白話教學文章，用生活化比喻 + 圖解，帶你從零基礎到考取經濟部 iPAS AI 應用規劃師初級證照。
        </p>
        <div class="flex items-center gap-4 mt-4 md:mt-6">
          <span class="px-3 py-1.5 text-xs bg-brand-accent-dark/10 text-brand-accent-dark rounded-full font-body">
            共 {totalLessons} 篇
          </span>
          <span class="px-3 py-1.5 text-xs bg-purple-600/10 text-purple-600 rounded-full font-body">
            初級認證
          </span>
          <span class="px-3 py-1.5 text-xs bg-emerald-600/10 text-emerald-600 rounded-full font-body">
            零基礎友善
          </span>
        </div>
      </div>

    </div>
  </section>

  <!-- Course Content -->
  <section class="relative pb-20 md:pb-28 overflow-hidden bg-white">
    <div class="site-container px-6 relative z-10">

      {sortedStages.map(([stageName, stageLessons], stageIdx) => (
        <div class="mb-10 md:mb-14">
          <!-- Stage Header -->
          <div class="flex items-center gap-4 mb-5 md:mb-6">
            <div class="w-10 h-10 md:w-12 md:h-12 rounded-xl gold-gradient flex items-center justify-center shrink-0">
              <span class="text-white font-heading font-bold text-sm md:text-base">{stageIdx + 1}</span>
            </div>
            <div>
              <h2 class="font-heading font-bold text-lg md:text-2xl text-brand-light-text">{stageName}</h2>
              <p class="text-xs md:text-sm text-brand-light-subtle font-body">{stageLessons.length} 篇</p>
            </div>
          </div>

          <!-- Lesson Cards -->
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {stageLessons.map((lesson) => (
              <a href={`/ipas/${lesson.slug}`}
                 class="group block p-5 md:p-6 bg-white border border-brand-light-border rounded-xl hover:border-brand-accent-dark/30 hover:shadow-md transition-all duration-300 no-underline">
                <div class="flex items-center gap-3 mb-3">
                  <span class="w-7 h-7 rounded-lg bg-brand-accent-dark/10 flex items-center justify-center text-xs font-heading font-bold text-brand-accent-dark shrink-0">
                    {String(lesson.order).padStart(2, '0')}
                  </span>
                  <span class="px-2 py-0.5 text-[10px] rounded-full bg-purple-600/10 text-purple-600 font-body">
                    {lesson.courseId}
                  </span>
                </div>
                <h3 class="font-heading font-semibold text-sm md:text-base leading-snug text-brand-light-text group-hover:text-brand-accent-dark transition-colors mb-2">
                  {lesson.title}
                </h3>
                <p class="text-xs text-brand-light-subtle leading-relaxed line-clamp-2">
                  {lesson.summary}
                </p>
              </a>
            ))}
          </div>
        </div>
      ))}

    </div>
  </section>

</Base>
