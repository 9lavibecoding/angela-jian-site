---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const lessons = (await getCollection('ipas')).sort((a, b) => a.data.order - b.data.order);

// Group by stage
const stages = new Map<string, typeof lessons>();
for (const lesson of lessons) {
  const key = lesson.data.stage;
  if (!stages.has(key)) stages.set(key, []);
  stages.get(key)!.push(lesson);
}
const sortedStages = [...stages.entries()].sort(
  (a, b) => a[1][0].data.stageOrder - b[1][0].data.stageOrder
);

const totalLessons = lessons.length;
---

<Base title="iPAS AI 應用規劃師｜證照備考教學 — Angela Jian" description="51 篇白話教學，從零開始帶你考取 iPAS AI 應用規劃師初級證照。">

  <section class="relative pt-28 md:pt-32 pb-12 md:pb-16 overflow-hidden bg-[#FFFEF7]">
    <div class="site-container px-6 relative z-10">

      <!-- Back link -->
      <a href="/" class="inline-flex items-center gap-2 text-brand-light-subtle text-sm font-body mb-8 md:mb-10 hover:text-brand-accent-dark transition-colors">
        <iconify-icon icon="solar:arrow-left-linear" class="text-lg"></iconify-icon>
        <span>返回首頁</span>
      </a>

      <!-- Header -->
      <div class="mb-10 md:mb-14">
        <div class="flex items-center gap-3 text-brand-light-subtle text-xs tracking-widest font-body uppercase mb-4 md:mb-6">
          <div class="w-8 h-px bg-brand-accent-dark"></div>
          <span>iPAS Certificate Course</span>
        </div>
        <h1 class="font-heading font-bold text-3xl md:text-5xl lg:text-6xl text-brand-light-text mb-4 md:mb-6">
          iPAS <span class="text-brand-accent-dark">AI 應用規劃師</span>
        </h1>
        <p class="text-base md:text-lg text-brand-light-subtle font-body leading-relaxed max-w-2xl">
          51 篇白話教學文章，用生活化比喻 + 圖解，帶你從零基礎到考取經濟部 iPAS AI 應用規劃師初級證照。
        </p>
        <div class="flex items-center gap-4 mt-4 md:mt-6">
          <span class="px-3 py-1.5 text-xs bg-brand-accent-dark/10 text-brand-accent-dark rounded-full font-body">
            共 {totalLessons} 篇
          </span>
          <span class="px-3 py-1.5 text-xs bg-purple-600/10 text-purple-600 rounded-full font-body">
            初級認證
          </span>
          <span class="px-3 py-1.5 text-xs bg-emerald-600/10 text-emerald-600 rounded-full font-body">
            零基礎友善
          </span>
        </div>
      </div>

    </div>
  </section>

  <!-- Course Content -->
  <section class="relative pb-20 md:pb-28 overflow-hidden bg-[#FFFEF7]">
    <div class="site-container px-6 relative z-10">

      {sortedStages.map(([stageName, stageLessons], stageIdx) => (
        <div class="mb-10 md:mb-14">
          <!-- Stage Header -->
          <div class="flex items-center gap-4 mb-5 md:mb-6">
            <div class="w-10 h-10 md:w-12 md:h-12 rounded-xl gold-gradient flex items-center justify-center shrink-0">
              <span class="text-white font-heading font-bold text-sm md:text-base">{stageIdx + 1}</span>
            </div>
            <div>
              <h2 class="font-heading font-bold text-lg md:text-2xl text-brand-light-text">{stageName}</h2>
              <p class="text-xs md:text-sm text-brand-light-subtle font-body">{stageLessons.length} 篇</p>
            </div>
          </div>

          <!-- Lesson Cards -->
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {stageLessons.map((lesson) => (
              <a href={`/ipas/${lesson.id}`}
                 class="group block p-5 md:p-6 bg-white border border-brand-light-border rounded-xl hover:border-brand-accent-dark/30 hover:shadow-md transition-all duration-300 no-underline">
                <div class="flex items-center gap-3 mb-3">
                  <span class="w-7 h-7 rounded-lg bg-brand-accent-dark/10 flex items-center justify-center text-xs font-heading font-bold text-brand-accent-dark shrink-0">
                    {String(lesson.data.order).padStart(2, '0')}
                  </span>
                  <span class="px-2 py-0.5 text-[10px] rounded-full bg-purple-600/10 text-purple-600 font-body">
                    {lesson.data.courseId}
                  </span>
                </div>
                <h3 class="font-heading font-semibold text-sm md:text-base leading-snug text-brand-light-text group-hover:text-brand-accent-dark transition-colors mb-2">
                  {lesson.data.title}
                </h3>
                <p class="text-xs text-brand-light-subtle leading-relaxed line-clamp-2">
                  {lesson.data.summary}
                </p>
              </a>
            ))}
          </div>
        </div>
      ))}

    </div>
  </section>

</Base>
