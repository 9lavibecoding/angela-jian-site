import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const lessons = await getCollection('ipas');
  return lessons.map(lesson => ({
    params: { slug: lesson.id },
    props: { lesson },
  }));
}

const { lesson } = Astro.props;
const { Content } = await render(lesson);

// Get all lessons for prev/next navigation
const allLessons = (await getCollection('ipas')).sort((a, b) => a.data.order - b.data.order);
const currentIdx = allLessons.findIndex(l => l.id === lesson.id);
const prevLesson = currentIdx > 0 ? allLessons[currentIdx - 1] : null;
const nextLesson = currentIdx < allLessons.length - 1 ? allLessons[currentIdx + 1] : null;
const canonicalURL = new URL(`/ipas/${lesson.id}`, Astro.site);

// Extract FAQ from markdown: find lines starting with **Q or **įŽŽ and their answer from the answer table
const rawBody = lesson.body || '';
const faqItems: { question: string; answer: string }[] = [];

// Parse answer table: | Q1 | **(B)** | č§Ģææå­ |
const answerTableMatch = rawBody.match(/### č§Ģį­čč§Ģæ[\s\S]*?\|[\s\S]*?\|/g);
if (answerTableMatch) {
  const tableRows = rawBody
    .split('### č§Ģį­čč§Ģæ')[1]
    ?.match(/\|\s*(?:Q?\d+|įŽŽ\s*\d+\s*éĄ?)\s*\|\s*\*?\*?\(?[A-D]\)?\*?\*?\s*\|\s*(.+?)\s*\|/g);

  // Also extract questions
  const questions = rawBody.match(/\*\*(?:Q\d+\.?|įŽŽ\s*\d+\s*éĄ)\*?\*?\s*(.+?)(?:\n|$)/g);

  if (questions && tableRows) {
    const limit = Math.min(questions.length, tableRows.length, 3); // max 3 FAQs per page
    for (let i = 0; i < limit; i++) {
      const q = questions[i]?.replace(/\*\*/g, '').replace(/^Q\d+\.?\s*|^įŽŽ\s*\d+\s*éĄ\s*/,'').trim();
      const aMatch = tableRows[i]?.match(/\|\s*(?:Q?\d+|įŽŽ\s*\d+\s*éĄ?)\s*\|\s*\*?\*?\(?([A-D])\)?\*?\*?\s*\|\s*(.+?)\s*\|/);
      const a = aMatch?.[2]?.replace(/\*\*/g, '').trim();
      if (q && a) {
        faqItems.push({ question: q, answer: a });
      }
    }
  }
}

// Fallback: always include a FAQ about the topic itself
if (faqItems.length === 0) {
  faqItems.push({
    question: lesson.data.title.replace(/[ïž:]/g, 'ïž').replace(/ïž$/, '') + 'ïž',
    answer: lesson.data.summary
  });
}
