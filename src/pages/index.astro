<script>
  document.addEventListener('DOMContentLoaded', () => {
    const statsBar = document.querySelector('.hero-stat')?.closest('.grid, .flex');
    if (!statsBar) return;

    const counters = statsBar.querySelectorAll('[data-target]');

    function easeOutExpo(t) {
      return t === 1 ? 1 : 1 - Math.pow(2, -10 * t);
    }

    function animateCounters() {
      const duration = 2000;

      counters.forEach((el) => {
        const target = parseInt(el.dataset.target, 10);
        const suffix = el.dataset.suffix || '';
        const start = performance.now();

        function update(now) {
          const elapsed = now - start;
          const progress = Math.min(elapsed / duration, 1);
          const value = Math.round(easeOutExpo(progress) * target);
          el.textContent = value + suffix;

          if (progress < 1) {
            requestAnimationFrame(update);
          }
        }

        requestAnimationFrame(update);
      });
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            animateCounters();
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.3 }
    );

    observer.observe(statsBar);
  });
</script>

<script>
  // About accordion ↔ image switching
  document.addEventListener('DOMContentLoaded', () => {
    const accordions = document.querySelectorAll<HTMLDetailsElement>('#aboutAccordion .about-accordion');
    const images = document.querySelectorAll<HTMLImageElement>('.about-img');

    function showImage(index: number) {
      images.forEach((img, i) => {
        img.style.opacity = i === index ? '1' : '0';
      });
    }

    // When an accordion opens, close others and switch image
    accordions.forEach(detail => {
      detail.addEventListener('toggle', () => {
        if (detail.open) {
          // Close all other accordions
          accordions.forEach(other => {
            if (other !== detail) other.removeAttribute('open');
          });
          // Show corresponding image
          const imgIndex = parseInt(detail.dataset.img || '0', 10);
          showImage(imgIndex);
        } else {
          // If all closed, show default image
          const anyOpen = [...accordions].some(d => d.open);
          if (!anyOpen) showImage(0);
        }
      });
    });
  });
</script>


