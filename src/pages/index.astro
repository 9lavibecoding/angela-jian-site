---
import Base from '../layouts/Base.astro';
import { getArticles } from '../lib/notion';

const articles = await getArticles();

const tagStyles: Record<string, string> = {
  accent: 'bg-brand-accent/10 text-brand-accent-dark',
  warm:   'bg-brand-warm-dark/10 text-brand-warm-dark',
  cool:   'bg-brand-cool/10 text-brand-cool',
  purple: 'bg-purple-600/10 text-purple-600',
};

// Card header pastel backgrounds & icons per tag color
const cardHeaderStyles: Record<string, { bg: string; icon: string }> = {
  accent: { bg: 'bg-indigo-100/60',  icon: 'solar:document-text-bold' },
  warm:   { bg: 'bg-amber-100/60',   icon: 'solar:lightbulb-bolt-bold' },
  cool:   { bg: 'bg-slate-100/60',   icon: 'solar:chart-2-bold' },
  purple: { bg: 'bg-purple-100/60',  icon: 'solar:settings-bold' },
};
---

<Base title="Angela Jian 簡琬庭 — Sr. Product Manager / AI Product Builder">

<!-- HERO SECTION -->
<section class="relative min-h-screen flex items-center overflow-hidden bg-white" id="hero">
  <div class="container mx-auto px-6 pt-28 md:pt-32 pb-12 relative z-10">

    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16 items-center">

      <!-- Left: Text Content -->
      <div>
        <!-- Title -->
        <h1 class="hero-title text-4xl md:text-5xl lg:text-[4.2rem] mb-6 text-brand-text">
          <span class="line"><span class="line-inner">Hi, I'm</span></span>
          <span class="line"><span class="line-inner text-brand-accent">Angela.</span></span>
          <span class="line"><span class="line-inner">I scale products</span></span>
          <span class="line"><span class="line-inner">that matter.</span></span>
        </h1>

        <!-- One-liner -->
        <p class="font-body text-brand-subtle text-base md:text-lg leading-relaxed mb-5 opacity-0 max-w-lg" id="heroDesc">
          把產品從 0 做到百萬用戶，用數據驅動成長與變現。
        </p>

        <!-- Hashtags -->
        <div class="flex flex-wrap gap-2 mb-8 opacity-0" id="heroTags">
          <span class="px-3 py-1.5 text-xs font-body rounded-full bg-indigo-50 text-brand-accent-dark">#AI Product Builder</span>
          <span class="px-3 py-1.5 text-xs font-body rounded-full bg-indigo-50 text-brand-accent-dark">#PM</span>
          <span class="px-3 py-1.5 text-xs font-body rounded-full bg-amber-50 text-brand-warm-dark">#AI產品思維實驗室 Creator</span>
          <span class="px-3 py-1.5 text-xs font-body rounded-full bg-emerald-50 text-emerald-700">#經濟部AI應用規劃師</span>
        </div>

        <!-- CTAs -->
        <div class="flex flex-wrap gap-4 opacity-0" id="heroCTAs">
          <a href="#articles" class="mag-btn px-8 py-4 bg-brand-accent text-white font-heading font-semibold rounded-full text-sm tracking-wide">
            <span>探索作品集</span>
          </a>
          <a href="#about" class="mag-btn px-8 py-4 border border-brand-light-border text-brand-text font-heading font-medium rounded-full text-sm tracking-wide hover:border-brand-accent hover:text-brand-accent transition-colors">
            <span>了解更多</span>
          </a>
        </div>
      </div>

      <!-- Right: Photo + Floating Badges -->
      <div class="relative flex justify-center md:justify-end">
        <!-- Main Photo -->
        <div class="hero-photo relative w-[280px] md:w-[380px] lg:w-[420px]">
          <img src="/angela.jpeg" alt="Angela Jian"
               class="w-full rounded-3xl object-cover aspect-[3/4] shadow-xl" loading="eager">
        </div>

        <!-- Floating Badges -->
        <div class="float-badge absolute -left-4 md:-left-8 top-1/4 bg-amber-100 rounded-2xl p-3 shadow-lg">
          <iconify-icon icon="solar:chart-2-bold" class="text-2xl text-amber-600"></iconify-icon>
        </div>
        <div class="float-badge absolute -right-2 md:-right-6 top-[15%] bg-indigo-100 rounded-2xl p-3 shadow-lg" style="animation-delay: 2s;">
          <iconify-icon icon="solar:verified-check-bold" class="text-2xl text-indigo-600"></iconify-icon>
        </div>
        <div class="float-badge absolute -left-2 md:-left-6 bottom-[20%] bg-emerald-100 rounded-2xl p-3 shadow-lg" style="animation-delay: 4s;">
          <iconify-icon icon="solar:users-group-rounded-bold" class="text-2xl text-emerald-600"></iconify-icon>
        </div>
      </div>

    </div>
  </div>

  <!-- Bottom Stats Bar -->
  <div class="absolute bottom-0 left-0 right-0 z-10 border-t border-brand-light-border bg-white/80 backdrop-blur-sm">
    <div class="container mx-auto px-6">
      <div class="grid grid-cols-3 gap-4 md:flex md:items-center md:justify-start md:gap-16 py-5 md:py-6">
        <div class="hero-stat flex flex-col md:flex-row items-center gap-1 md:gap-3 text-center md:text-left">
          <span id="stat-mau" class="text-xl md:text-2xl font-heading font-bold text-brand-accent" data-target="600" data-suffix="K">0</span>
          <span class="text-[10px] md:text-xs text-brand-subtle font-body">MAU Scaled</span>
        </div>
        <div class="hidden md:block w-px h-6 bg-brand-light-border"></div>
        <div class="hero-stat flex flex-col md:flex-row items-center gap-1 md:gap-3 text-center md:text-left">
          <span id="stat-views" class="text-xl md:text-2xl font-heading font-bold text-brand-accent" data-target="100" data-suffix="M+">0</span>
          <span class="text-[10px] md:text-xs text-brand-subtle font-body">Content Views</span>
        </div>
        <div class="hidden md:block w-px h-6 bg-brand-light-border"></div>
        <div class="hero-stat flex flex-col md:flex-row items-center gap-1 md:gap-3 text-center md:text-left">
          <span id="stat-revenue" class="text-xl md:text-2xl font-heading font-bold text-brand-accent" data-target="120" data-suffix="%">0</span>
          <span class="text-[10px] md:text-xs text-brand-subtle font-body">Revenue Growth</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ABOUT SECTION -->
<section class="relative py-20 md:py-28 overflow-hidden bg-brand-light-surface" id="about">
  <div class="container mx-auto px-6 relative z-10">

    <!-- Section Header -->
    <div class="mb-12">
      <div class="flex items-center gap-3 text-brand-subtle text-xs tracking-widest font-body uppercase mb-4">
        <div class="w-8 h-px bg-brand-accent"></div>
        <span>About</span>
      </div>
      <h2 class="font-heading font-black text-3xl md:text-5xl leading-tight text-brand-text">
        關於<span class="text-brand-accent">我</span>
      </h2>
      <p class="text-base md:text-lg font-body text-brand-subtle mt-4 max-w-2xl">
        從營運到產品領導，8 年間橫跨使用者、商業與團隊三個維度做產品。
      </p>
    </div>

    <!-- Accordion + Image Layout -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-10 items-start">

      <!-- Left: Accordion -->
      <div class="space-y-0 divide-y divide-brand-light-border" id="aboutAccordion">

        <details class="about-accordion group" data-img="1" open>
          <summary class="flex items-center justify-between py-5 md:py-6 cursor-pointer list-none">
            <span class="font-heading font-semibold text-base md:text-lg text-brand-text">從 0 到百萬用戶</span>
            <iconify-icon icon="solar:alt-arrow-down-linear" class="text-brand-subtle text-xl transition-transform duration-300 group-open:rotate-180"></iconify-icon>
          </summary>
          <div class="pb-5 md:pb-6">
            <p class="text-sm text-brand-subtle leading-relaxed mb-3">在 TikTok 與 LiveIn 等高成長產品中，實際參與從 0 到 1、再到百萬用戶的全過程。成長不是功能堆疊，而是設計對的飛輪。</p>
            <div class="flex flex-wrap gap-2">
              <span class="px-2.5 py-1 text-[11px] font-body bg-brand-accent/10 text-brand-accent-dark rounded-full">MAU 600K</span>
              <span class="px-2.5 py-1 text-[11px] font-body bg-brand-accent/10 text-brand-accent-dark rounded-full">100M+ Views</span>
            </div>
          </div>
        </details>

        <details class="about-accordion group" data-img="2">
          <summary class="flex items-center justify-between py-5 md:py-6 cursor-pointer list-none">
            <span class="font-heading font-semibold text-base md:text-lg text-brand-text">數據驅動變現</span>
            <iconify-icon icon="solar:alt-arrow-down-linear" class="text-brand-subtle text-xl transition-transform duration-300 group-open:rotate-180"></iconify-icon>
          </summary>
          <div class="pb-5 md:pb-6">
            <p class="text-sm text-brand-subtle leading-relaxed mb-3">用數據與用戶行為驗證每一個產品決策，而非靠直覺。在 Fintech 產品中透過混合變現策略，提升收入 120%。</p>
            <div class="flex flex-wrap gap-2">
              <span class="px-2.5 py-1 text-[11px] font-body bg-brand-warm-dark/10 text-brand-warm-dark rounded-full">Revenue +120%</span>
              <span class="px-2.5 py-1 text-[11px] font-body bg-brand-warm-dark/10 text-brand-warm-dark rounded-full">Hybrid Monetization</span>
            </div>
          </div>
        </details>

        <details class="about-accordion group" data-img="3">
          <summary class="flex items-center justify-between py-5 md:py-6 cursor-pointer list-none">
            <span class="font-heading font-semibold text-base md:text-lg text-brand-text">跨職能對齊</span>
            <iconify-icon icon="solar:alt-arrow-down-linear" class="text-brand-subtle text-xl transition-transform duration-300 group-open:rotate-180"></iconify-icon>
          </summary>
          <div class="pb-5 md:pb-6">
            <p class="text-sm text-brand-subtle leading-relaxed mb-3">對齊方向、拆解問題，讓設計、工程與商業能在同一個決策框架下前進。帶領 20+ 人跨職能團隊交付產品成果。</p>
            <div class="flex flex-wrap gap-2">
              <span class="px-2.5 py-1 text-[11px] font-body bg-brand-cool/10 text-brand-cool rounded-full">20+ 人團隊</span>
              <span class="px-2.5 py-1 text-[11px] font-body bg-brand-cool/10 text-brand-cool rounded-full">A/B Testing</span>
              <span class="px-2.5 py-1 text-[11px] font-body bg-brand-cool/10 text-brand-cool rounded-full">Cross-functional</span>
            </div>
          </div>
        </details>

      </div>

      <!-- Right: Image Stack -->
      <div class="relative rounded-2xl overflow-hidden w-full max-w-[408px] ml-auto md:sticky md:top-28" style="aspect-ratio: 4/3;">
        <img src="https://images.unsplash.com/photo-1531482615713-2afd69097998?w=800&q=80&auto=format"
             alt="Product work" data-about-img="0"
             class="about-img absolute inset-0 w-full h-full object-cover transition-opacity duration-500 opacity-100" />
        <img src="https://images.unsplash.com/photo-1552664730-d307ca884978?w=800&q=80&auto=format"
             alt="Team scaling" data-about-img="1"
             class="about-img absolute inset-0 w-full h-full object-cover transition-opacity duration-500 opacity-0" />
        <img src="https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=800&q=80&auto=format"
             alt="Data analytics" data-about-img="2"
             class="about-img absolute inset-0 w-full h-full object-cover transition-opacity duration-500 opacity-0" />
        <img src="https://images.unsplash.com/photo-1517245386807-bb43f82c33c4?w=800&q=80&auto=format"
             alt="Cross-functional team" data-about-img="3"
             class="about-img absolute inset-0 w-full h-full object-cover transition-opacity duration-500 opacity-0" />
      </div>

    </div>
  </div>
</section>

<!-- PORTFOLIO SECTION -->
<section class="relative py-20 md:py-28 overflow-hidden bg-white" id="portfolio">
  <div class="container mx-auto px-6 relative z-10">

    <!-- Header (consistent with other sections) -->
    <div class="flex items-center gap-3 text-brand-subtle text-xs tracking-widest font-body uppercase mb-4 md:mb-6">
      <div class="w-8 h-px bg-brand-accent"></div>
      <span>Selected Works</span>
    </div>
    <h2 class="font-heading font-black text-3xl md:text-5xl mb-4 text-brand-text">
      AI<span class="text-brand-accent">作品集</span>
    </h2>
    <p class="text-brand-subtle font-body text-sm md:text-base max-w-2xl leading-relaxed mb-10 md:mb-14">
      A curated collection of AI-powered projects spanning data analytics, automation, and creative applications.
    </p>

    <!-- Project Grid -->
    <div class="border-t border-brand-light-border">

      <!-- Row 1 -->
      <div class="grid grid-cols-1 md:grid-cols-2">
        <!-- Card 1 -->
        <a href="/articles/ai-powered-competitive-intelligence" class="group block p-6 md:p-10 border-b md:border-r border-brand-light-border hover:bg-brand-light-surface/50 transition-colors duration-300 no-underline">
          <div class="flex items-center gap-3 mb-4">
            <span class="text-3xl md:text-4xl font-heading font-light italic text-brand-accent/20">01</span>
            <p class="text-[11px] tracking-[0.2em] uppercase text-brand-subtle font-body">Dashboard · OpenAI · Supabase</p>
          </div>
          <h3 class="font-heading font-bold text-xl md:text-2xl text-brand-text mb-3 group-hover:text-brand-accent transition-colors">AI 數據分析 Dashboard</h3>
          <p class="text-sm text-brand-subtle leading-relaxed mb-6">結合 OpenAI 與 Supabase，打造即時數據分析儀表板，支援自然語言查詢與智慧圖表生成。</p>
          <span class="inline-flex items-center gap-2 text-xs tracking-[0.15em] uppercase text-brand-subtle font-body group-hover:text-brand-accent transition-colors">
            View Project <span class="transition-transform duration-300 group-hover:translate-x-1">→</span>
          </span>
        </a>

        <!-- Card 2 -->
        <a href="/articles/human-in-the-loop-ai-accounting" class="group block p-6 md:p-10 border-b border-brand-light-border hover:bg-brand-light-surface/50 transition-colors duration-300 no-underline">
          <div class="flex items-center gap-3 mb-4">
            <span class="text-3xl md:text-4xl font-heading font-light italic text-brand-accent/20">02</span>
            <p class="text-[11px] tracking-[0.2em] uppercase text-brand-subtle font-body">AI Agent · Human-in-the-Loop</p>
          </div>
          <h3 class="font-heading font-bold text-xl md:text-2xl text-brand-text mb-3 group-hover:text-brand-accent transition-colors">Human-in-the-Loop AI 會計師</h3>
          <p class="text-sm text-brand-subtle leading-relaxed mb-6">結合人工審核與模型分類，自動化帳務處理流程，準確率高達 97%。</p>
          <span class="inline-flex items-center gap-2 text-xs tracking-[0.15em] uppercase text-brand-subtle font-body group-hover:text-brand-accent transition-colors">
            View Project <span class="transition-transform duration-300 group-hover:translate-x-1">→</span>
          </span>
        </a>
      </div>

      <!-- Row 2 -->
      <div class="grid grid-cols-1 md:grid-cols-2">
        <!-- Card 3 -->
        <a href="#" class="group block p-6 md:p-10 border-b md:border-r border-brand-light-border hover:bg-brand-light-surface/50 transition-colors duration-300 no-underline">
          <div class="flex items-center gap-3 mb-4">
            <span class="text-3xl md:text-4xl font-heading font-light italic text-brand-accent/20">03</span>
            <p class="text-[11px] tracking-[0.2em] uppercase text-brand-subtle font-body">AI Agent · PDF Automation</p>
          </div>
          <h3 class="font-heading font-bold text-xl md:text-2xl text-brand-text mb-3 group-hover:text-brand-accent transition-colors">AI 產品型錄財報</h3>
          <p class="text-sm text-brand-subtle leading-relaxed mb-6">AI Agent 自動產出一頁式產品型錄，結合市場數據與專業視覺排版。</p>
          <span class="inline-flex items-center gap-2 text-xs tracking-[0.15em] uppercase text-brand-subtle font-body group-hover:text-brand-accent transition-colors">
            View Project <span class="transition-transform duration-300 group-hover:translate-x-1">→</span>
          </span>
        </a>

        <!-- Card 4 -->
        <a href="#" class="group block p-6 md:p-10 border-b border-brand-light-border hover:bg-brand-light-surface/50 transition-colors duration-300 no-underline">
          <div class="flex items-center gap-3 mb-4">
            <span class="text-3xl md:text-4xl font-heading font-light italic text-brand-accent/20">04</span>
            <p class="text-[11px] tracking-[0.2em] uppercase text-brand-subtle font-body">GPT · Storytelling</p>
          </div>
          <h3 class="font-heading font-bold text-xl md:text-2xl text-brand-text mb-3 group-hover:text-brand-accent transition-colors">月亮枕頭故事</h3>
          <p class="text-sm text-brand-subtle leading-relaxed mb-6">GPT 驅動的互動式兒童睡前故事，每晚生成獨特的冒險旅程。</p>
          <span class="inline-flex items-center gap-2 text-xs tracking-[0.15em] uppercase text-brand-subtle font-body group-hover:text-brand-accent transition-colors">
            View Project <span class="transition-transform duration-300 group-hover:translate-x-1">→</span>
          </span>
        </a>
      </div>

    </div>

  </div>
</section>


<!-- ARTICLES SECTION -->
<section class="relative py-20 md:py-28 overflow-hidden bg-brand-light-surface" id="articles">
  <div class="container mx-auto px-6 relative z-10">

    <div class="flex items-center justify-between mb-8 flex-wrap gap-4 md:gap-6">
      <div>
        <div class="flex items-center gap-3 text-brand-subtle text-xs tracking-widest font-body uppercase mb-4 md:mb-6">
          <div class="w-8 h-px bg-brand-accent"></div>
          <span>Articles</span>
        </div>
        <h2 class="font-heading font-black text-3xl md:text-5xl text-brand-text">
          最新<span class="text-brand-accent">文章</span>
        </h2>
      </div>
      <a href="/articles" class="mag-btn px-5 md:px-6 py-2.5 md:py-3 border border-brand-light-border text-brand-subtle font-body text-sm rounded-full hover:text-brand-accent hover:border-brand-accent transition-colors">
        <span>查看全部</span>
      </a>
    </div>

    <!-- Article Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">

      {articles.slice(0, 4).map((article, i) => {
        const header = cardHeaderStyles[article.tagColors[0]] || cardHeaderStyles.accent;
        return (
          <a href={`/articles/${article.slug}`}
             class="stagger-col card-hover rounded-2xl bg-white border border-brand-light-border block overflow-hidden group"
             data-stagger={i}>
            {/* Pastel header with icon */}
            <div class={`${header.bg} flex items-center justify-center py-8 md:py-10`}>
              <iconify-icon icon={header.icon} class="text-4xl md:text-5xl text-brand-text/15 group-hover:text-brand-text/30 transition-colors"></iconify-icon>
            </div>
            {/* Content */}
            <div class="p-4 md:p-5">
              <div class="flex items-center gap-2 mb-2 md:mb-3 flex-wrap">
                {article.tags.map((tag, j) => (
                  <span class={`px-2 md:px-2.5 py-0.5 md:py-1 text-[10px] md:text-[11px] rounded-full font-body ${tagStyles[article.tagColors[j]] || tagStyles.accent}`}>{tag}</span>
                ))}
                <span class="text-[10px] md:text-[11px] text-brand-subtle font-body">{article.date}</span>
              </div>
              <h3 class="font-heading font-semibold text-sm md:text-base mb-2 leading-snug text-brand-text line-clamp-2">{article.title}</h3>
              {article.summary && (
                <p class="text-xs text-brand-subtle leading-relaxed line-clamp-2 md:line-clamp-3">{article.summary}</p>
              )}
            </div>
          </a>
        );
      })}

      <!-- Newsletter CTA Card -->
      <div class="stagger-col p-4 md:p-5 rounded-2xl bg-gradient-to-br from-indigo-50 to-amber-50 border border-indigo-100 relative overflow-hidden flex flex-col justify-center" data-stagger="4">
        <iconify-icon icon="solar:letter-bold" class="text-brand-accent text-2xl mb-2 relative z-10"></iconify-icon>
        <div class="text-sm font-heading font-bold text-brand-text mb-1 relative z-10">AI Applied Playbook</div>
        <p class="text-xs text-brand-subtle font-body mb-1.5 relative z-10">AIPM 思維實驗室電子報</p>
        <p class="text-[11px] text-brand-accent/60 font-body mb-4 leading-relaxed italic relative z-10">"把 AI 從工具變成工作流程的實戰手冊"</p>
        <a href="https://www.linkedin.com/newsletters/ai-applied-playbook%EF%BD%9Caipm-%E6%80%9D%E7%B6%AD%E5%AF%A6%E9%A9%97%E5%AE%A4-7402251966258720768" target="_blank" class="mag-btn px-4 py-2.5 bg-brand-accent text-white font-body font-semibold rounded-full text-xs tracking-wide inline-flex relative z-10">
          <span>免費訂閱</span>
        </a>
      </div>
    </div>
  </div>
</section>

<!-- CONTACT SECTION -->
<section class="relative py-20 md:py-28 overflow-hidden bg-white" id="contact">
  <div class="container mx-auto px-6 relative z-10">
    <div class="max-w-4xl mx-auto text-center">
      <div class="flex items-center justify-center gap-3 text-brand-subtle text-xs tracking-widest font-body uppercase mb-6 md:mb-8">
        <div class="w-8 h-px bg-brand-accent"></div>
        <span>Contact</span>
        <div class="w-8 h-px bg-brand-accent"></div>
      </div>

      <h2 class="font-heading font-black text-4xl md:text-7xl lg:text-8xl mb-6 md:mb-8 leading-tight text-brand-text">
        Let's<br><span class="text-brand-accent">Connect</span>
      </h2>

      <p class="text-base md:text-lg text-brand-subtle font-body max-w-2xl mx-auto mb-8 md:mb-12 leading-relaxed">
        如果你正在尋找一位能把問題想清楚、把產品做到位的產品夥伴——歡迎跟我聊聊。
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 md:gap-6 mb-10 md:mb-16">
        <a href="mailto:an9lajian@gmail.com" class="mag-btn w-full sm:w-auto px-8 md:px-10 py-4 md:py-5 bg-brand-accent text-white font-heading font-bold rounded-full text-sm md:text-base tracking-wide text-center">
          <span>an9lajian@gmail.com</span>
        </a>
