---
import Base from '../layouts/Base.astro';
import { getArticles } from '../lib/notion';

const articles = await getArticles();

const tagStyles: Record<string, string> = {
  accent: 'bg-amber-100 text-amber-800 font-medium',
  warm:   'bg-orange-100 text-orange-800 font-medium',
  cool:   'bg-slate-200 text-slate-700 font-medium',
  purple: 'bg-purple-100 text-purple-700 font-medium',
};

const cardHeaderStyles: Record<string, { bg: string; icon: string }> = {
  accent: { bg: 'bg-amber-50',   icon: 'solar:document-text-bold' },
  warm:   { bg: 'bg-orange-50',  icon: 'solar:lightbulb-bolt-bold' },
  cool:   { bg: 'bg-slate-100',  icon: 'solar:chart-2-bold' },
  purple: { bg: 'bg-purple-50',  icon: 'solar:settings-bold' },
};

const featuredArticles = articles.slice(0, 2);
const moreArticles = articles.slice(2, 6);
---

<Base title="AI PM INSIDER — 產品人的 AI 轉型指南">

<!-- FAQ Schema for SEO -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Angela Jian 簡琬庭是誰？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "資深產品經理與 AI 產品建造者，擁有 8 年以上行動應用成長與變現經驗，曾將產品從 0 推進至 60 萬 MAU。同時經營「AI產品思維實驗室」，並具備經濟部 AI 應用規劃師資格。"
      }
    },
    {
      "@type": "Question",
      "name": "AI PM INSIDER 是什麼？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "AI PM INSIDER 是 Angela Jian 的個人網站與部落格，分享 AI 產品管理、產品成長策略與變現實戰經驗，幫助產品人建立 AI 時代的產品思維。"
      }
    },
    {
      "@type": "Question",
      "name": "AI 產品經理和傳統產品經理有什麼不同？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "AI 產品經理除了具備傳統 PM 的用戶洞察與專案管理能力外，還需要理解 AI 模型的能力邊界、數據品質對產品的影響，以及如何設計人機協作的產品體驗。"
      }
    },
    {
      "@type": "Question",
      "name": "產品冷啟動階段如何獲取第一批用戶？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "關鍵在於找到最小可行受眾（MVA），透過精準的社群經營、內容行銷或策略合作快速驗證產品價值，再利用數據反饋迭代產品與獲客策略。"
      }
    },
    {
      "@type": "Question",
      "name": "如何與 Angela Jian 合作？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "歡迎透過網站聯繫表單或 LinkedIn 聯繫，可以討論產品策略諮詢、AI 產品規劃或團隊內訓等合作方式。"
      }
    },
    {
      "@type": "Question",
      "name": "行動應用如何有效導入 AI 功能？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "從用戶痛點出發，優先選擇 AI 能明顯提升體驗的場景（如個人化推薦、智慧搜尋），以 MVP 快速上線驗證效果，避免為了 AI 而 AI。"
      }
    }
  ]
})} />

<!-- ==================== 1. HERO ==================== -->
<section class="relative overflow-hidden bg-white" id="hero">
  <div class="site-container px-6 pt-28 md:pt-36 pb-16 md:pb-20 relative z-10">
    <div class="flex flex-col md:flex-row items-center gap-8 md:gap-16">
      <div class="flex-1 text-center md:text-left">
        <h1 class="hero-title text-4xl md:text-[3.5rem] lg:text-[4.2rem] mb-6 text-brand-text leading-tight">
          <span class="line"><span class="line-inner">產品人的</span></span>
          <span class="line"><span class="line-inner"><span class="gold-text">AI 轉型</span>指南</span></span>
        </h1>
        <p class="font-body text-brand-subtle text-base md:text-lg leading-relaxed mb-6 opacity-0 max-w-lg mx-auto md:mx-0" id="heroDesc">
          從 AI 產品策略、工具實戰到職涯轉型！資深 PM 的第一手觀察與實踐。
        </p>
        <div class="flex flex-wrap gap-2 mb-8 opacity-0 justify-center md:justify-start" id="heroTags">
          <span class="px-3 py-1.5 text-xs font-body rounded-full bg-amber-50 text-brand-accent-dark">#AI 產品管理</span>
          <span class="px-3 py-1.5 text-xs font-body rounded-full bg-amber-50 text-brand-warm-dark">#PM 工具實戰</span>
          <span class="px-3 py-1.5 text-xs font-body rounded-full bg-emerald-50 text-emerald-700">#職涯成長</span>
        </div>
        <div class="flex flex-wrap gap-4 opacity-0 justify-center md:justify-start" id="heroCTAs">
          <a href="#articles" class="mag-btn px-6 md:px-8 py-3.5 md:py-4 gold-gradient text-white font-heading font-semibold rounded-full text-sm tracking-wide">
            <span>開始閱讀</span>
          </a>
          <a href="#about" class="mag-btn px-6 md:px-8 py-3.5 md:py-4 border border-brand-light-border text-brand-text font-heading font-medium rounded-full text-sm tracking-wide hover:border-brand-accent hover:text-brand-accent transition-colors">
            <span>認識作者</span>
          </a>
        </div>
      </div>
      <div class="hero-photo shrink-0 hidden md:block md:w-80 lg:w-[26rem]">
        <img src="/hero-illustration.webp" alt="AI PM INSIDER — AI 產品管理"
             class="w-full h-auto" loading="eager">
      </div>
    </div>
  </div>
</section>

<!-- ==================== 2. ARTICLES ==================== -->
<section class="relative py-16 md:py-24 overflow-hidden bg-[#F9FAFB] border-t border-gray-100" id="articles">
  <div class="site-container px-6 relative z-10">
    <div class="flex items-center justify-between mb-8 flex-wrap gap-4">
      <div>
        <div class="flex items-center gap-3 text-brand-subtle text-xs tracking-widest font-body uppercase mb-4">
          <div class="w-8 h-px bg-brand-accent"></div>
          <span>Latest Articles</span>
        </div>
        <h2 class="font-heading font-black text-3xl md:text-5xl text-brand-text">
          精選<span class="text-brand-accent">文章</span>
        </h2>
      </div>
      <a href="/articles" class="mag-btn px-4 md:px-6 py-2 md:py-3 border border-brand-light-border text-brand-subtle font-body text-xs md:text-sm rounded-full hover:text-brand-accent hover:border-brand-accent transition-colors no-underline shrink-0">
        <span>查看全部</span>
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
      {featuredArticles.map((article, i) => {
        const header = cardHeaderStyles[article.tagColors[0]] || cardHeaderStyles.accent;
        return (
          <a href={`/articles/${article.slug}`}
             class="card-hover rounded-2xl bg-white border border-brand-light-border block overflow-hidden group no-underline"
             data-stagger={i}>
            <div class={`${header.bg} flex items-center justify-center py-10 md:py-14`}>
              <iconify-icon icon={header.icon} class="text-5xl md:text-6xl text-brand-text/15 group-hover:text-brand-text/30 transition-colors"></iconify-icon>
            </div>
            <div class="p-5 md:p-6">
              <div class="flex items-center gap-2 mb-3 flex-wrap">
                {article.tags.map((tag, j) => (
                  <span class={`px-2.5 py-1 text-[11px] rounded-full font-body ${tagStyles[article.tagColors[j]] || tagStyles.accent}`}>{tag}</span>
                ))}
                <span class="text-[11px] text-brand-subtle font-body">{article.date}</span>
              </div>
              <h3 class="font-heading font-bold text-lg md:text-xl mb-2 leading-snug text-brand-text">{article.title}</h3>
              {article.summary && (
                <p class="text-sm text-brand-subtle leading-relaxed line-clamp-3">{article.summary}</p>
              )}
            </div>
          </a>
        );
      })}
    </div>

    {moreArticles.length > 0 && (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {moreArticles.map((article, i) => {
          return (
            <a href={`/articles/${article.slug}`}
               class="card-hover rounded-xl bg-white border border-brand-light-border block overflow-hidden group no-underline p-4 md:p-5"
               data-stagger={i + 2}>
              <div class="flex items-center gap-2 mb-2 flex-wrap">
                {article.tags.slice(0, 1).map((tag, j) => (
                  <span class={`px-2 py-0.5 text-[10px] rounded-full font-body ${tagStyles[article.tagColors[j]] || tagStyles.accent}`}>{tag}</span>
                ))}
              </div>
              <h4 class="font-heading font-semibold text-sm mb-1.5 leading-snug text-brand-text line-clamp-2">{article.title}</h4>
              <span class="text-[11px] text-brand-subtle font-body">{article.date}</span>
            </a>
          );
        })}
      </div>
    )}
  </div>
</section>

<!-- ==================== 3. iPAS + EXAM ==================== -->
<section class="relative py-20 md:py-28 overflow-hidden bg-white border-t border-gray-100" id="ipas">
  <div class="site-container px-6 relative z-10">

    <div class="flex items-center gap-3 text-brand-subtle text-xs tracking-widest font-body uppercase mb-4 md:mb-6">
      <div class="w-8 h-px bg-brand-accent"></div>
      <span>iPAS Certificate</span>
    </div>
    <h2 class="font-heading font-black text-3xl md:text-5xl text-brand-text mb-2">iPAS AI <span class="text-brand-accent">備考專區</span></h2>
    <p class="font-body text-brand-subtle text-base md:text-lg leading-relaxed mb-10">免費 50 篇白話教學 + 付費 1000 題題庫，用最有效率的方式拿下 iPAS AI 應用規劃師證照。</p>

    <div class="grid md:grid-cols-2 gap-6">
      <!-- 免費課程 -->
      <a href="/ipas" class="group block bg-white rounded-2xl border border-brand-light-border p-8 hover:shadow-lg hover:border-brand-accent/30 transition-all no-underline">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-12 h-12 rounded-xl bg-emerald-100 flex items-center justify-center">
            <iconify-icon icon="solar:book-2-bold" class="text-2xl text-emerald-600"></iconify-icon>
          </div>
          <span class="px-3 py-1 text-xs font-body font-medium rounded-full bg-emerald-100 text-emerald-700">免費</span>
        </div>
        <h3 class="font-heading font-bold text-xl text-brand-text mb-2 group-hover:text-brand-accent transition-colors">50 篇白話教學課程</h3>
        <p class="font-body text-sm text-brand-subtle leading-relaxed mb-4">
          涵蓋 AI 基礎、機器學習、生成式 AI、法規治理，用生活化比喻 + 圖解帶你從零基礎到考前衝刺。
        </p>
        <div class="flex flex-wrap gap-2">
          <span class="px-2 py-0.5 text-[10px] font-body rounded-full bg-slate-100 text-slate-600">AI 基礎概念</span>
          <span class="px-2 py-0.5 text-[10px] font-body rounded-full bg-slate-100 text-slate-600">生成式 AI</span>
          <span class="px-2 py-0.5 text-[10px] font-body rounded-full bg-slate-100 text-slate-600">3 套模擬考</span>
        </div>
      </a>

      <!-- 付費題庫 -->
      <a href="/exam" class="group block bg-white rounded-2xl border border-brand-light-border p-8 hover:shadow-lg hover:border-brand-accent/30 transition-all no-underline">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-12 h-12 rounded-xl bg-amber-100 flex items-center justify-center">
            <iconify-icon icon="solar:document-add-bold" class="text-2xl text-brand-accent"></iconify-icon>
          </div>
          <span class="px-3 py-1 text-xs font-body font-medium rounded-full bg-red-100 text-red-600">NT$699 早鳥價</span>
        </div>
        <h3 class="font-heading font-bold text-xl text-brand-text mb-2 group-hover:text-brand-accent transition-colors">1000 題互動題庫</h3>
        <p class="font-body text-sm text-brand-subtle leading-relaxed mb-4">
          章節練習、答對率統計、3 套模擬考卷（計時 60 分鐘）、PDF 離線下載，一次買斷永久使用。
        </p>
        <div class="flex flex-wrap gap-2">
          <span class="px-2 py-0.5 text-[10px] font-body rounded-full bg-slate-100 text-slate-600">L11 基礎 300 題</span>
          <span class="px-2 py-0.5 text-[10px] font-body rounded-full bg-slate-100 text-slate-600">L12 生成式 300 題</span>
          <span class="px-2 py-0.5 text-[10px] font-body rounded-full bg-slate-100 text-slate-600">綜合 400 題</span>
        </div>
      </a>
    </div>

  </div>
</section>

<!-- ==================== 4. PORTFOLIO ==================== -->
