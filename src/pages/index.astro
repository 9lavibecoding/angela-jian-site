        </div>
      </div>
      <div class="flex-1 text-center md:text-left">
        <div class="flex items-center gap-3 text-brand-subtle text-xs tracking-widest font-body uppercase mb-4 justify-center md:justify-start">
          <div class="w-8 h-px bg-brand-accent"></div>
          <span>About the Author</span>
        </div>
