      </a>
    </div>

  </div>
</section>

<!-- ==================== 5. ABOUT ==================== -->
<section class="relative py-20 md:py-28 overflow-hidden bg-white border-t border-gray-100" id="about">
  <div class="site-container px-6 relative z-10">
    <div class="flex flex-col md:flex-row items-center gap-10 md:gap-16">
      <div class="shrink-0">
        <div class="w-52 md:w-72 rounded-2xl overflow-hidden shadow-lg">
          <img src="/avatar-vector.webp" alt="Angela Jian"
