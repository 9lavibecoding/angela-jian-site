---
import Base from '../layouts/Base.astro';
---

<Base title="找不到頁面 — AI PM INSIDER" description="你要找的頁面不存在">

<main class="pt-28 pb-20 min-h-screen bg-white">
  <div class="site-container px-6">
    <div class="max-w-lg mx-auto text-center py-20">
      <p class="font-heading font-black text-8xl text-brand-accent mb-4">404</p>
      <h1 class="font-heading font-bold text-2xl text-brand-text mb-3">找不到這個頁面</h1>
      <p class="font-body text-brand-subtle mb-8">你要找的頁面可能已經移除或網址有誤。</p>
      <a href="/" class="mag-btn px-8 py-3.5 gold-gradient text-white font-heading font-semibold rounded-full text-sm no-underline">
        <span>回到首頁</span>
      </a>
    </div>
  </div>
</main>

</Base>
