---
import Base from '../../layouts/Base.astro';
---

<Base title="PM → AI PM 能力自評表 — Angela Jian" description="評估你的 AI 產品經理準備度，獲取個人化學習建議">

<main class="pt-28 pb-20 min-h-screen bg-white">
  <div class="site-container px-6">

    <!-- Header -->
    <div class="mb-12">
      <a href="/#portfolio" class="inline-flex items-center gap-2 text-sm font-body text-brand-subtle hover:text-brand-accent transition-colors mb-6">
        <iconify-icon icon="solar:arrow-left-linear"></iconify-icon>
        返回作品集
      </a>
      <h1 class="font-heading font-bold text-3xl md:text-4xl text-brand-text mb-3">PM → AI PM 能力自評表</h1>
      <p class="font-body text-brand-subtle text-lg">評估你的 AI 產品經理準備度，獲取個人化學習建議</p>
    </div>

    <div class="grid lg:grid-cols-3 gap-8">

      <!-- Left: Assessment Form -->
      <div class="lg:col-span-2 space-y-8">

        <!-- Category 1 -->
        <div class="bg-brand-light-surface rounded-2xl p-6 md:p-8 border border-brand-light-border">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 rounded-xl bg-indigo-100 flex items-center justify-center">
              <iconify-icon icon="solar:clipboard-list-bold" class="text-xl text-brand-accent"></iconify-icon>
            </div>
            <div>
              <h2 class="font-heading font-bold text-lg text-brand-text">產品管理基礎</h2>
              <span class="text-xs font-body text-brand-subtle">每項 5 分</span>
            </div>
          </div>
          <div class="space-y-3">
            <label class="assessment-item group" data-weight="5">
              <input type="checkbox" class="assessment-checkbox sr-only" />
              <span class="checkbox-visual"></span>
              <span class="font-body text-brand-text group-hover:text-brand-accent transition-colors">能獨立撰寫 PRD 和 User Story</span>
            </label>
            <label class="assessment-item group" data-weight="5">
              <input type="checkbox" class="assessment-checkbox sr-only" />
              <span class="checkbox-visual"></span>
              <span class="font-body text-brand-text group-hover:text-brand-accent transition-colors">有 A/B Testing 實戰經驗</span>
            </label>
            <label class="assessment-item group" data-weight="5">
              <input type="checkbox" class="assessment-checkbox sr-only" />
              <span class="checkbox-visual"></span>
              <span class="font-body text-brand-text group-hover:text-brand-accent transition-colors">熟悉敏捷開發流程</span>
            </label>
            <label class="assessment-item group" data-weight="5">
              <input type="checkbox" class="assessment-checkbox sr-only" />
              <span class="checkbox-visual"></span>
              <span class="font-body text-brand-text group-hover:text-brand-accent transition-colors">能進行用戶訪談並提取洞察</span>
            </label>
            <label class="assessment-item group" data-weight="5">
              <input type="checkbox" class="assessment-checkbox sr-only" />
              <span class="checkbox-visual"></span>
              <span class="font-body text-brand-text group-hover:text-brand-accent transition-colors">有數據驅動決策的習慣</span>
            </label>
          </div>
        </div>

        <!-- Category 2 -->
        <div class="bg-brand-light-surface rounded-2xl p-6 md:p-8 border border-brand-light-border">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 rounded-xl bg-violet-100 flex items-center justify-center">
              <iconify-icon icon="solar:cpu-bolt-bold" class="text-xl text-violet-600"></iconify-icon>
            </div>
            <div>
              <h2 class="font-heading font-bold text-lg text-brand-text">AI 素養</h2>
              <span class="text-xs font-body text-brand-subtle">每項 8 分</span>
            </div>
          </div>
          <div class="space-y-3">
            <label class="assessment-item group" data-weight="8">
              <input type="checkbox" class="assessment-checkbox sr-only" />
              <span class="checkbox-visual"></span>
              <span class="font-body text-brand-text group-hover:text-brand-accent transition-colors">理解 LLM、ML 模型的基本原理</span>
            </label>
            <label class="assessment-item group" data-weight="8">
              <input type="checkbox" class="assessment-checkbox sr-only" />
              <span class="checkbox-visual"></span>
              <span class="font-body text-brand-text group-hover:text-brand-accent transition-colors">知道什麼問題適合用 AI 解決</span>
            </label>
            <label class="assessment-item group" data-weight="8">
              <input type="checkbox" class="assessment-checkbox sr-only" />
              <span class="checkbox-visual"></span>
              <span class="font-body text-brand-text group-hover:text-brand-accent transition-colors">了解 Hallucination、Model Drift 等概念</span>
            </label>
            <label class="assessment-item group" data-weight="8">
              <input type="checkbox" class="assessment-checkbox sr-only" />
              <span class="checkbox-visual"></span>
              <span class="font-body text-brand-text group-hover:text-brand-accent transition-colors">能評估 AI 功能的 Precision 和 Recall</span>
            </label>
            <label class="assessment-item group" data-weight="8">
              <input type="checkbox" class="assessment-checkbox sr-only" />
              <span class="checkbox-visual"></span>
              <span class="font-body text-brand-text group-hover:text-brand-accent transition-colors">理解 Fine-tuning vs Prompt Engineering 的 trade-off</span>
            </label>
          </div>
        </div>

        <!-- Category 3 -->
        <div class="bg-brand-light-surface rounded-2xl p-6 md:p-8 border border-brand-light-border">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 rounded-xl bg-amber-100 flex items-center justify-center">
              <iconify-icon icon="solar:chat-round-dots-bold" class="text-xl text-amber-600"></iconify-icon>
            </div>
            <div>
              <h2 class="font-heading font-bold text-lg text-brand-text">Prompt Engineering</h2>
              <span class="text-xs font-body text-brand-subtle">每項 7 分</span>
            </div>
          </div>
          <div class="space-y-3">
            <label class="assessment-item group" data-weight="7">
              <input type="checkbox" class="assessment-checkbox sr-only" />
              <span class="checkbox-visual"></span>
              <span class="font-body text-brand-text group-hover:text-brand-accent transition-colors">會使用 Role + Context + Format 框架</span>
            </label>
            <label class="assessment-item group" data-weight="7">
              <input type="checkbox" class="assessment-checkbox sr-only" />
              <span class="checkbox-visual"></span>
              <span class="font-body text-brand-text group-hover:text-brand-accent transition-colors">理解 System Prompt 的設計邏輯</span>
            </label>
            <label class="assessment-item group" data-weight="7">
              <input type="checkbox" class="assessment-checkbox sr-only" />
              <span class="checkbox-visual"></span>
              <span class="font-body text-brand-text group-hover:text-brand-accent transition-colors">知道 Few-shot vs Zero-shot 的差異</span>
            </label>
            <label class="assessment-item group" data-weight="7">
              <input type="checkbox" class="assessment-checkbox sr-only" />
              <span class="checkbox-visual"></span>
              <span class="font-body text-brand-text group-hover:text-brand-accent transition-colors">能設計 Prompt 的評估指標</span>
            </label>
            <label class="assessment-item group" data-weight="7">
              <input type="checkbox" class="assessment-checkbox sr-only" />
              <span class="checkbox-visual"></span>
              <span class="font-body text-brand-text group-hover:text-brand-accent transition-colors">有在產品中設計 AI Workflow 的經驗</span>
            </label>
          </div>
        </div>

        <!-- Category 4 -->
        <div class="bg-brand-light-surface rounded-2xl p-6 md:p-8 border border-brand-light-border">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 rounded-xl bg-emerald-100 flex items-center justify-center">
              <iconify-icon icon="solar:database-bold" class="text-xl text-emerald-600"></iconify-icon>
            </div>
            <div>
              <h2 class="font-heading font-bold text-lg text-brand-text">數據思維</h2>
              <span class="text-xs font-body text-brand-subtle">每項 6 分</span>
            </div>
          </div>
          <div class="space-y-3">
            <label class="assessment-item group" data-weight="6">
              <input type="checkbox" class="assessment-checkbox sr-only" />
              <span class="checkbox-visual"></span>
              <span class="font-body text-brand-text group-hover:text-brand-accent transition-colors">會寫基礎 SQL 查詢</span>
            </label>
            <label class="assessment-item group" data-weight="6">
              <input type="checkbox" class="assessment-checkbox sr-only" />
              <span class="checkbox-visual"></span>
              <span class="font-body text-brand-text group-hover:text-brand-accent transition-colors">能判斷數據品質和潛在 bias</span>
            </label>
            <label class="assessment-item group" data-weight="6">
              <input type="checkbox" class="assessment-checkbox sr-only" />
              <span class="checkbox-visual"></span>
              <span class="font-body text-brand-text group-hover:text-brand-accent transition-colors">理解 Data Pipeline 的基本架構</span>
            </label>
            <label class="assessment-item group" data-weight="6">
              <input type="checkbox" class="assessment-checkbox sr-only" />
              <span class="checkbox-visual"></span>
              <span class="font-body text-brand-text group-hover:text-brand-accent transition-colors">有定義數據指標（北極星指標）的經驗</span>
            </label>
            <label class="assessment-item group" data-weight="6">
              <input type="checkbox" class="assessment-checkbox sr-only" />
              <span class="checkbox-visual"></span>
              <span class="font-body text-brand-text group-hover:text-brand-accent transition-colors">了解 AI 模型對訓練數據品質的依賴</span>
            </label>
          </div>
        </div>

      </div>

      <!-- Right: Score Panel (sticky) -->
      <div class="lg:col-span-1">
        <div class="lg:sticky lg:top-28 space-y-6">

          <!-- Score Card -->
          <div class="bg-brand-light-surface rounded-2xl p-6 md:p-8 border border-brand-light-border text-center">
            <p class="font-body text-sm text-brand-subtle mb-4">你的 AI PM 準備度</p>
            <div class="relative w-40 h-40 mx-auto mb-4">
              <svg class="w-40 h-40 -rotate-90" viewBox="0 0 160 160">
                <circle cx="80" cy="80" r="70" fill="none" stroke="#e5e7eb" stroke-width="10" />
                <circle id="scoreRing" cx="80" cy="80" r="70" fill="none" stroke="#6366f1" stroke-width="10"
                  stroke-linecap="round"
                  stroke-dasharray="439.82"
                  stroke-dashoffset="439.82"
                  style="transition: stroke-dashoffset 0.5s ease, stroke 0.3s ease;" />
              </svg>
              <div class="absolute inset-0 flex flex-col items-center justify-center">
                <span id="scoreNumber" class="font-heading font-bold text-4xl text-brand-text">0</span>
                <span class="font-body text-xs text-brand-subtle">/ 130</span>
              </div>
            </div>
            <div id="levelBadge" class="inline-block px-4 py-1.5 rounded-full text-sm font-body font-medium bg-gray-100 text-brand-subtle transition-all duration-300">
              開始勾選吧！
            </div>
          </div>

          <!-- Result Card -->
          <div id="resultCard" class="bg-brand-light-surface rounded-2xl p-6 md:p-8 border border-brand-light-border hidden">
            <p id="resultEmoji" class="text-3xl mb-3"></p>
            <h3 id="resultTitle" class="font-heading font-bold text-lg text-brand-text mb-2"></h3>
            <p id="resultDesc" class="font-body text-sm text-brand-subtle leading-relaxed mb-5"></p>
            <div id="resultLinks" class="space-y-2">
              <p class="font-heading font-semibold text-sm text-brand-text mb-1">推薦閱讀</p>
            </div>
          </div>

          <!-- Reset Button -->
          <button id="resetBtn" class="w-full py-3 rounded-xl border border-brand-light-border font-body text-sm text-brand-subtle hover:text-brand-accent hover:border-brand-accent transition-colors duration-300">
            <iconify-icon icon="solar:refresh-linear" class="mr-1 align-middle"></iconify-icon>
            重新評估
          </button>

        </div>
      </div>

    </div>

    <!-- Bottom Note -->
    <div class="mt-16 text-center">
      <p class="font-body text-sm text-brand-subtle">這份自評表基於 Angela Jian 的 AI PM 能力框架設計，僅供參考。真正的能力來自實戰。</p>
    </div>

  </div>
</main>

<style>
  .assessment-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    border-radius: 0.75rem;
    cursor: pointer;
    transition: background-color 0.2s ease;
    user-select: none;
  }
  .assessment-item:hover {
    background-color: rgba(99, 102, 241, 0.04);
  }

  .checkbox-visual {
    flex-shrink: 0;
    width: 1.375rem;
    height: 1.375rem;
    border-radius: 0.375rem;
    border: 2px solid #d1d5db;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
    position: relative;
  }
  .checkbox-visual::after {
    content: '';
    display: block;
    width: 0.5rem;
    height: 0.25rem;
    border-left: 2px solid white;
    border-bottom: 2px solid white;
    transform: rotate(-45deg) translateY(-1px);
    opacity: 0;
    transition: opacity 0.15s ease;
  }

  .assessment-checkbox:checked + .checkbox-visual {
    background-color: #6366f1;
    border-color: #6366f1;
  }
  .assessment-checkbox:checked + .checkbox-visual::after {
    opacity: 1;
  }

  .assessment-checkbox:checked ~ span:last-child {
    color: #6366f1;
  }
</style>

<script is:inline>
(function() {
  const MAX_SCORE = 130;
  const CIRCUMFERENCE = 2 * Math.PI * 70; // ~439.82

  const levels = [
    {
      min: 0, max: 30,
      emoji: '\u{1F331}', title: '起步階段',
      desc: '你有扎實的 PM 基礎，現在是開始接觸 AI 的好時機。建議從 Prompt Engineering 入手，這是投報率最高的起點。',
      badgeColor: 'bg-green-100 text-green-700',
      strokeColor: '#22c55e',
      links: [
        { text: '從傳統 PM 轉型 AI PM 的職涯路徑', url: '/articles/traditional-pm-to-ai-pm-career' },
        { text: '產品經理的 AI 工具箱', url: '/articles/ai-tools-for-product-managers' },
      ]
    },
    {
      min: 31, max: 65,
      emoji: '\u{1F33F}', title: '成長階段',
      desc: '你已經開始建立 AI 認知，接下來需要更多實戰。建議找一個實際專案練手，把理論轉化為經驗。',
      badgeColor: 'bg-emerald-100 text-emerald-700',
      strokeColor: '#10b981',
      links: [
        { text: '從傳統 PM 轉型 AI PM 的職涯路徑', url: '/articles/traditional-pm-to-ai-pm-career' },
        { text: '產品經理的 AI 工具箱', url: '/articles/ai-tools-for-product-managers' },
      ]
    },
    {
      min: 66, max: 100,
      emoji: '\u{1F333}', title: '進階階段',
      desc: '你具備了 AI PM 的核心能力，可以開始主導 AI 產品的規劃。建議深入 Evaluation 和 Data Pipeline 的實務操作。',
      badgeColor: 'bg-indigo-100 text-indigo-700',
      strokeColor: '#6366f1',
      links: [
        { text: 'PM 技能樹 vs AI PM 能力矩陣', url: '/articles/pm-skill-tree-vs-ai-pm-matrix' },
        { text: 'AI 驅動的競品分析', url: '/articles/ai-powered-competitive-intelligence' },
      ]
    },
    {
      min: 101, max: 130,
      emoji: '\u{1F680}', title: '專家階段',
      desc: '你已經是稀缺的 AI PM 人才！建議開始分享經驗、建立影響力，同時關注最新的 AI 產品設計 Pattern。',
      badgeColor: 'bg-violet-100 text-violet-700',
      strokeColor: '#8b5cf6',
      links: [
        { text: 'PM 技能樹 vs AI PM 能力矩陣', url: '/articles/pm-skill-tree-vs-ai-pm-matrix' },
        { text: 'AI 驅動的競品分析', url: '/articles/ai-powered-competitive-intelligence' },
      ]
    },
  ];

  function getLevel(score) {
    if (score === 0) return null;
    return levels.find(l => score >= l.min && score <= l.max);
  }

  function update() {
    var score = 0;
    var items = document.querySelectorAll('.assessment-item');
    items.forEach(function(item) {
      var cb = item.querySelector('.assessment-checkbox');
      if (cb && cb.checked) {
        score += parseInt(item.getAttribute('data-weight') || '0', 10);
      }
    });

    // Update score number
    document.getElementById('scoreNumber').textContent = score;

    // Update ring
    var ring = document.getElementById('scoreRing');
    var offset = CIRCUMFERENCE - (score / MAX_SCORE) * CIRCUMFERENCE;
    ring.setAttribute('stroke-dashoffset', offset);

    var level = getLevel(score);
    var badge = document.getElementById('levelBadge');
    var card = document.getElementById('resultCard');

    if (!level) {
      badge.className = 'inline-block px-4 py-1.5 rounded-full text-sm font-body font-medium bg-gray-100 text-brand-subtle transition-all duration-300';
      badge.textContent = '開始勾選吧！';
      ring.setAttribute('stroke', '#6366f1');
      card.classList.add('hidden');
      return;
    }

    // Update badge
    badge.className = 'inline-block px-4 py-1.5 rounded-full text-sm font-body font-medium transition-all duration-300 ' + level.badgeColor;
    badge.textContent = level.emoji + ' ' + level.title;

    // Update ring color
    ring.setAttribute('stroke', level.strokeColor);

    // Update result card
    card.classList.remove('hidden');
    document.getElementById('resultEmoji').textContent = level.emoji;
    document.getElementById('resultTitle').textContent = level.title;
    document.getElementById('resultDesc').textContent = level.desc;

    var linksContainer = document.getElementById('resultLinks');
    linksContainer.innerHTML = '<p class="font-heading font-semibold text-sm text-brand-text mb-1">推薦閱讀</p>';
    level.links.forEach(function(link) {
      var a = document.createElement('a');
      a.href = link.url;
      a.className = 'block font-body text-sm text-brand-accent hover:underline';
      a.textContent = '→ ' + link.text;
      linksContainer.appendChild(a);
    });
  }

  // Attach listeners
  document.querySelectorAll('.assessment-checkbox').forEach(function(cb) {
    cb.addEventListener('change', update);
  });

  // Reset
  document.getElementById('resetBtn').addEventListener('click', function() {
    document.querySelectorAll('.assessment-checkbox').forEach(function(cb) {
      cb.checked = false;
    });
    update();
  });

  // Initial
  update();
})();
</script>

</Base>
