---
import Base from '../../layouts/Base.astro';
import { getArticles, getArticleBySlug } from '../../lib/notion';

export async function getStaticPaths() {
  const articles = await getArticles();
  return articles.map(a => ({
    params: { slug: a.slug },
  }));
}

const { slug } = Astro.params;
const article = await getArticleBySlug(slug as string);

if (!article) {
  return Astro.redirect('/404');
}
---

<Base title={`${article.title} — Angela Jian`} description={article.summary} ogImage={article.image}>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": article.title,
    "description": article.summary,
    "datePublished": article.date?.replaceAll('.', '-'),
    "author": { "@type": "Person", "name": "Angela Jian 簡琬庭" },
    ...(article.image ? { "image": article.image } : {}),
  })} />

  <!-- Article Header -->
  <section class="relative pt-28 md:pt-32 pb-12 md:pb-16 overflow-hidden bg-brand-light-bg">
    <div class="site-container px-6 md:px-12 relative z-10">
      <div class="max-w-3xl mx-auto">

        <!-- Back Link -->
        <a href="/#articles" class="inline-flex items-center gap-2 text-brand-light-subtle text-sm font-body mb-8 md:mb-10 hover:text-brand-accent-dark transition-colors">
          <iconify-icon icon="solar:arrow-left-linear" class="text-lg"></iconify-icon>
          <span>返回首頁</span>
        </a>

        <!-- Tags + Date -->
        <div class="flex items-center gap-2 md:gap-3 mb-4 md:mb-6 flex-wrap">
          {article.tags.map(tag => (
            <span class="px-3 py-1.5 text-xs bg-brand-accent-dark/10 text-brand-accent-dark rounded-full font-body">{tag}</span>
          ))}
          <span class="text-sm text-brand-light-subtle font-body">{article.date}</span>
        </div>

        <!-- Title -->
        <h1 class="font-heading font-bold text-2xl md:text-5xl lg:text-6xl leading-tight mb-6 md:mb-8 text-brand-light-text">
          {article.title}
        </h1>

        <!-- Author -->
        <div class="flex items-center gap-4 mb-8 md:mb-12 pb-8 md:pb-12 border-b border-brand-light-border">
          <div class="w-12 h-12 rounded-full overflow-hidden border border-brand-accent-dark/30">
            <img src="/angela.jpeg"
                 alt="Angela Jian" class="w-full h-full object-cover">
          </div>
          <div>
            <div class="font-heading font-semibold text-sm text-brand-light-text">Angela Jian 簡琬庭</div>
            <div class="text-xs text-brand-light-subtle font-body">Sr. Product Manager / AI Product Builder</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Cover Image -->
  {article.image && (
    <section class="relative pb-12 md:pb-16 overflow-hidden bg-brand-light-bg">
      <div class="site-container px-6 md:px-12 relative z-10">
        <div class="max-w-4xl mx-auto">
          <img src={article.image} alt={article.title}
               class="w-full rounded-xl md:rounded-2xl object-cover max-h-[500px]" />
        </div>
      </div>
    </section>
  )}

  <!-- Article Content -->
  <section class="relative pb-20 md:pb-32 overflow-hidden bg-brand-light-bg">
    <div class="site-container px-6 md:px-12 relative z-10">
      <div class="max-w-3xl mx-auto article-content-light text-base">
        {article.content ? (
          <div set:html={article.content} />
        ) : (
          <div class="text-center py-16 md:py-20">
            <iconify-icon icon="solar:document-text-bold" class="text-brand-accent-dark text-5xl mb-4"></iconify-icon>
            <p class="text-brand-light-subtle font-body text-lg mb-6">本文內容即將上線</p>
            <p class="text-brand-light-subtle font-body text-sm mb-8">完整文章內容正在準備中，敬請期待。</p>
            {article.url && (
              <a href={article.url} target="_blank" rel="noopener noreferrer"
                 class="mag-btn px-6 md:px-8 py-3 md:py-4 bg-brand-accent-dark text-white font-heading font-semibold rounded-full text-sm tracking-wide inline-flex items-center gap-2">
                <span>前往 LinkedIn 閱讀原文</span>
                <iconify-icon icon="solar:arrow-right-up-linear" class="text-lg"></iconify-icon>
              </a>
            )}
          </div>
        )}
      </div>

      <!-- Back to Articles -->
      <div class="max-w-3xl mx-auto mt-12 md:mt-16 pt-8 md:pt-12 border-t border-brand-light-border">
        <a href="/#articles" class="mag-btn px-6 md:px-8 py-3 md:py-4 border border-brand-light-border text-brand-light-text font-heading font-medium rounded-full text-sm tracking-wide hover:border-brand-accent-dark hover:text-brand-accent-dark transition-colors">
          <span>← 返回所有文章</span>
        </a>
      </div>
    </div>
  </section>

</Base>
